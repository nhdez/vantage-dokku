<% content_for :title, "Activity Log ##{@activity_log.id}" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-history me-2 text-primary"></i>
            Activity Log Details
          </h1>
          <p class="text-muted mb-0">
            Detailed view of activity log #<%= @activity_log.id %>
          </p>
        </div>
        <div>
          <%= link_to admin_activity_logs_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Logs
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Log Details -->
    <div class="col-lg-8">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>Log Entry #<%= @activity_log.id %>
          </h6>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <p><strong>Action:</strong></p>
              <p><%= @activity_log.action.titleize %></p>
            </div>
            <div class="col-md-6">
              <p><strong>Occurred At:</strong></p>
              <p><%= @activity_log.occurred_at.strftime('%Y-%m-%d %H:%M:%S %Z') %></p>
            </div>
          </div>
          <hr>
          <p><strong>Details:</strong></p>
          <p><%= @activity_log.details %></p>
        </div>
      </div>

      <!-- Request Parameters -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-server me-2"></i>Request Parameters
          </h6>
        </div>
        <div class="card-body">
          <% if @activity_log.params_data.present? %>
            <pre class="bg-dark text-white p-3 rounded"><code><%= JSON.pretty_generate(@activity_log.params_data) %></code></pre>
          <% else %>
            <p class="text-muted">No parameters were recorded for this action.</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- User & Request Info -->
    <div class="col-lg-4">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-user me-2"></i>User Information
          </h6>
        </div>
        <div class="card-body">
          <p><strong>User:</strong> <%= @activity_log.user.full_name %></p>
          <p><strong>Email:</strong> <%= @activity_log.user.email %></p>
        </div>
      </div>

      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-network-wired me-2"></i>Request Information
          </h6>
        </div>
        <div class="card-body">
          <p><strong>IP Address:</strong> <%= @activity_log.ip_address %></p>
          <p><strong>Controller:</strong> <%= @activity_log.controller_name %></p>
          <p><strong>Action:</strong> <%= @activity_log.action_name %></p>
          <hr>
          <p><strong>User Agent:</strong></p>
          <p class="small text-muted"><%= @activity_log.user_agent %></p>
        </div>
      </div>
    </div>
  </div>
</div>