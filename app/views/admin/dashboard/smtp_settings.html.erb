<% content_for :title, "SMTP Settings" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-envelope-open-text me-2 text-primary"></i>
            SMTP Settings
          </h1>
          <p class="text-muted mb-0">Configure and verify email delivery settings</p>
        </div>
        <div>
          <%= link_to admin_root_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cogs me-2"></i>Email Configuration
          </h6>
        </div>
        <div class="card-body">
          <% if @env_fully_configured %>
            <!-- Environment Variables are Set -->
            <div class="alert alert-success">
              <i class="fas fa-check-circle me-2"></i>
              <strong>SMTP is Configured via Environment Variables</strong>
              <p class="mb-0">Your SMTP settings are securely managed through environment variables. You can enable or disable sending real emails below.</p>
            </div>

            <%= form_with url: admin_smtp_settings_path, method: :patch, local: true do |f| %>
              <div class="mb-4 border rounded p-3">
                <div class="form-check form-switch">
                  <%= f.check_box :smtp_enabled, 
                      { checked: AppSetting.get('smtp_enabled', false), class: "form-check-input" }, 
                      "true", "false" %>
                  <label class="form-check-label" for="smtp_enabled">
                    <strong>Enable Real Email Delivery</strong>
                  </label>
                  <div class="form-text">
                    When enabled, the application will send emails using the configured SMTP server. When disabled, it will use the development `letter_opener` gem.
                  </div>
                </div>
              </div>

              <!-- Display non-sensitive ENV vars -->
              <div class="row">
                <% @present_env_vars.each do |key, value| %>
                  <% unless key.include?('PASSWORD') || key.include?('USERNAME') %>
                    <div class="col-md-6 mb-3">
                      <label class="form-label"><strong><%= key.humanize %></strong></label>
                      <input type="text" class="form-control" value="<%= value %>" readonly>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <div class="d-flex justify-content-end mt-4">
                <%= f.submit "Save Settings", class: "btn btn-primary" %>
              </div>
            <% end %>

          <% else %>
            <!-- Environment Variables are Missing -->
            <div class="alert alert-danger">
              <i class="fas fa-times-circle me-2"></i>
              <strong>Action Required: Missing Environment Variables</strong>
              <p>To enable email delivery, you must set the following environment variables and restart the application:</p>
              <ul>
                <% @missing_env_vars.each do |var| %>
                  <li><code><%= var %></code></li>
                <% end %>
              </ul>
              <p class="mb-0">Once these are set, you can return to this page to enable email delivery.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <!-- Test Email Section -->
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-paper-plane me-2"></i>Test Email
          </h6>
        </div>
        <div class="card-body">
          <% if @env_fully_configured %>
            <p class="text-muted small">Send a test email to <strong><%= current_user.email %></strong> to verify your configuration.</p>
            <%= form_with url: admin_test_email_path, method: :post, local: true do |f| %>
              <div class="d-grid">
                <%= f.submit "Send Test Email", class: "btn btn-info" %>
              </div>
            <% end %>
          <% else %>
            <p class="text-muted">Please configure your SMTP environment variables before sending a test email.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>