<% content_for :title, "OAuth Settings" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fab fa-google me-2 text-primary"></i>
            OAuth Settings
          </h1>
          <p class="text-muted mb-0">Configure third-party authentication providers</p>
        </div>
        <div>
          <%= link_to admin_root_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fab fa-google me-2"></i>Google OAuth 2.0
          </h6>
        </div>
        <div class="card-body">
          <% if @google_creds_set %>
            <div class="alert alert-success">
              <i class="fas fa-check-circle me-2"></i>
              <strong>Environment Variables Found</strong>
              <p class="mb-0">Your Google OAuth credentials are correctly configured in the environment.</p>
            </div>

            <%= form_with url: admin_oauth_settings_path, method: :patch, local: true do |f| %>
              <!-- Enable/Disable Toggle -->
              <div class="mb-4 border rounded p-3">
                <div class="form-check form-switch">
                  <%= f.check_box "oauth[google_oauth_enabled]", 
                      { checked: @google_oauth_enabled.enabled, class: "form-check-input" }, 
                      "true", "false" %>
                  <label class="form-check-label" for="oauth_google_oauth_enabled">
                    <strong>Enable Google Sign-In</strong>
                  </label>
                  <div class="form-text">When enabled, users will see a "Sign in with Google" button on the login page.</div>
                </div>
              </div>

              <!-- Display Credentials (Read-Only) -->
              <div class="mb-3">
                <label class="form-label"><strong>Client ID</strong></label>
                <input type="text" class="form-control" value="<%= @google_client_id %>" readonly>
                <div class="form-text">Loaded from <code>GOOGLE_CLIENT_ID</code> environment variable.</div>
              </div>

              <div class="mb-3">
                <label class="form-label"><strong>Client Secret</strong></label>
                <input type="text" class="form-control" value="********************" readonly>
                <div class="form-text">Loaded from <code>GOOGLE_CLIENT_SECRET</code> environment variable.</div>
              </div>

              <div class="d-flex justify-content-end mt-4">
                <%= f.submit "Save Settings", class: "btn btn-primary" %>
              </div>
            <% end %>
          <% else %>
            <div class="alert alert-danger">
              <i class="fas fa-times-circle me-2"></i>
              <strong>Action Required: Missing Environment Variables</strong>
              <p>To enable Google OAuth, you must set the following environment variables and restart the application:</p>
              <ul>
                <li><code>GOOGLE_CLIENT_ID</code></li>
                <li><code>GOOGLE_CLIENT_SECRET</code></li>
              </ul>
              <p class="mb-0">These values can be obtained from the <a href="https://console.cloud.google.com/" target="_blank" rel="noopener noreferrer">Google Cloud Console</a>.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>Configuration Steps
          </h6>
        </div>
        <div class="card-body">
          <ol>
            <li class="mb-2">Go to the <a href="https://console.cloud.google.com/" target="_blank" rel="noopener noreferrer">Google Cloud Console</a>.</li>
            <li class="mb-2">Create a new project or select an existing one.</li>
            <li class="mb-2">Navigate to "APIs & Services" > "Credentials".</li>
            <li class="mb-2">Create an "OAuth client ID" for a "Web application".</li>
            <li class="mb-2">
              Add the following to your "Authorized redirect URIs":<br>
              <code><%= request.base_url %>/users/auth/google_oauth2/callback</code>
            </li>
            <li class="mb-2">Copy the generated Client ID and Client Secret.</li>
            <li class="mb-2">Set them as <code>GOOGLE_CLIENT_ID</code> and <code>GOOGLE_CLIENT_SECRET</code> environment variables for your application.</li>
            <li class="mb-2">Restart your application server.</li>
            <li class="mb-2">Return to this page and enable Google Sign-In.</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</div>
