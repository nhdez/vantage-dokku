<% content_for :title, "Database Configuration - #{@deployment.name}" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-database me-2 text-primary"></i>
            Database Configuration
          </h1>
          <p class="text-muted mb-0">Set up database services for <%= @deployment.name %></p>
        </div>
        <div>
          <%= link_to @deployment, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to App
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Database Configuration Form -->
    <div class="col-md-8">
      <% if @has_conflicts %>
        <div class="card shadow mb-4 border-start border-4 border-info">
          <div class="card-body py-3">
            <p class="mb-1 fw-semibold">
              <i class="fas fa-info-circle text-info me-2"></i>You already have these variables set manually:
              <% @database_configuration.has_environment_variable_conflict?.each do |var| %>
                <code class="ms-1"><%= var %></code>
              <% end %>
            </p>
            <p class="mb-0 text-muted small">
              Configuring a managed database here will update those variables to point to the new Dokku-managed instance.
              To keep your external database instead, just leave this page as-is.
              You can also <%= link_to "remove the variables manually", manage_environment_deployment_path(@deployment) %> if you no longer need them.
            </p>
          </div>
        </div>
      <% end %>

      <!-- Database Selection Form -->
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-database me-2"></i>Database Services
          </h6>
        </div>
        <div class="card-body">
          <%= form_with model: @database_configuration, url: update_database_configuration_deployment_path(@deployment), method: :post, local: false, id: "database-form" do |form| %>
            <p class="text-muted mb-4">
              Select a database and Dokku will install the plugin, create the instance, link it to your app,
              and set <code>DATABASE_URL</code> (and <code>REDIS_URL</code> if selected) as environment variables automatically.
              Setup runs in the background and typically takes a few minutes.
            </p>

            <!-- Database Type Selection -->
            <div class="mb-4">
              <label class="form-label">
                <i class="fas fa-database me-2"></i>Primary Database
              </label>
              <div class="row">
                <!-- PostgreSQL Option -->
                <div class="col-md-6 mb-3">
                  <div class="card border <%= @database_configuration.database_type == 'postgres' ? 'border-primary' : 'border-light' %>">
                    <div class="card-body p-3">
                      <div class="form-check">
                        <%= form.radio_button :database_type, 'postgres',
                            class: "form-check-input",
                            id: "database_postgres" %>
                        <%= form.label "database_postgres", class: "form-check-label flex-grow-1" do %>
                          <div class="d-flex align-items-center">
                            <i class="fas fa-database text-primary me-2"></i>
                            <div class="flex-grow-1">
                              <strong>PostgreSQL</strong>
                              <br><small class="text-muted">Advanced open-source relational database</small>
                              <br><small class="badge bg-success">Recommended</small>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- MySQL Option -->
                <div class="col-md-6 mb-3">
                  <div class="card border <%= @database_configuration.database_type == 'mysql' ? 'border-primary' : 'border-light' %>">
                    <div class="card-body p-3">
                      <div class="form-check">
                        <%= form.radio_button :database_type, 'mysql',
                            class: "form-check-input",
                            id: "database_mysql" %>
                        <%= form.label "database_mysql", class: "form-check-label flex-grow-1" do %>
                          <div class="d-flex align-items-center">
                            <i class="fas fa-database text-warning me-2"></i>
                            <div class="flex-grow-1">
                              <strong>MySQL</strong>
                              <br><small class="text-muted">Popular open-source relational database</small>
                              <br><small class="badge bg-info">New</small>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="row">
                <!-- MariaDB Option -->
                <div class="col-md-6 mb-3">
                  <div class="card border <%= @database_configuration.database_type == 'mariadb' ? 'border-primary' : 'border-light' %>">
                    <div class="card-body p-3">
                      <div class="form-check">
                        <%= form.radio_button :database_type, 'mariadb',
                            class: "form-check-input",
                            id: "database_mariadb" %>
                        <%= form.label "database_mariadb", class: "form-check-label flex-grow-1" do %>
                          <div class="d-flex align-items-center">
                            <i class="fas fa-database text-info me-2"></i>
                            <div class="flex-grow-1">
                              <strong>MariaDB</strong>
                              <br><small class="text-muted">MySQL-compatible database fork</small>
                              <br><small class="badge bg-info">New</small>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- MongoDB Option -->
                <div class="col-md-6 mb-3">
                  <div class="card border <%= @database_configuration.database_type == 'mongo' ? 'border-primary' : 'border-light' %>">
                    <div class="card-body p-3">
                      <div class="form-check">
                        <%= form.radio_button :database_type, 'mongo',
                            class: "form-check-input",
                            id: "database_mongo" %>
                        <%= form.label "database_mongo", class: "form-check-label flex-grow-1" do %>
                          <div class="d-flex align-items-center">
                            <i class="fas fa-leaf text-success me-2"></i>
                            <div class="flex-grow-1">
                              <strong>MongoDB</strong>
                              <br><small class="text-muted">Document-oriented NoSQL database</small>
                              <br><small class="badge bg-info">New</small>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Redis Option -->
            <div class="mb-4">
              <label class="form-label">
                <i class="fas fa-memory me-2"></i>Additional Services
              </label>
              <div class="card border <%= @database_configuration.redis_enabled? ? 'border-success' : 'border-light' %>">
                <div class="card-body p-3">
                  <div class="form-check">
                    <%= form.check_box :redis_enabled,
                        class: "form-check-input",
                        id: "redis_enabled" %>
                    <%= form.label "redis_enabled", class: "form-check-label flex-grow-1" do %>
                      <div class="d-flex align-items-center">
                        <i class="fas fa-memory text-success me-2"></i>
                        <div class="flex-grow-1">
                          <strong>Redis</strong>
                          <br><small class="text-muted">In-memory data structure store (caching, sessions, queues)</small>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>

            <!-- Database Information Display -->
            <% if @database_configuration.persisted? %>
              <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Current Configuration:</strong>
                <ul class="mb-0 mt-2">
                  <li><strong>Database:</strong> <%= @database_configuration.display_name %> (<code><%= @database_configuration.database_name %></code>)</li>
                  <% if @database_configuration.redis_enabled? %>
                    <li><strong>Redis:</strong> <%= @database_configuration.redis_display_name %></li>
                  <% end %>
                  <li><strong>Status:</strong>
                    <span class="badge <%= @database_configuration.status_class %>">
                      <%= @database_configuration.status_text %>
                    </span>
                  </li>
                </ul>
              </div>

              <!-- Connection Details Card -->
              <% if @database_configuration.configured? %>
                <div class="card shadow-sm mb-4">
                  <div class="card-header bg-primary text-white py-2">
                    <h6 class="m-0">
                      <i class="fas fa-plug me-2"></i>Connection Details
                    </h6>
                  </div>
                  <div class="card-body">
                    <p class="text-muted mb-3">
                      <i class="fas fa-info-circle me-1"></i>
                      Use these connection strings in your application to connect to your databases.
                    </p>

                    <!-- Database URL -->
                    <% if @database_configuration.database_url.present? %>
                      <div class="mb-3">
                        <label class="form-label mb-1">
                          <i class="fas fa-database text-primary me-1"></i>
                          <strong><%= @database_configuration.environment_variable_name %></strong>
                        </label>
                        <div class="input-group">
                          <input type="text"
                                 class="form-control font-monospace small"
                                 id="database-url-input"
                                 value="<%= @database_configuration.database_url %>"
                                 readonly>
                          <button class="btn btn-outline-secondary"
                                  type="button"
                                  onclick="copyFieldToClipboard('database-url-input', this)"
                                  title="Copy to clipboard">
                            <i class="fas fa-copy"></i>
                          </button>
                        </div>
                        <small class="text-muted">
                          <i class="fas fa-check text-success me-1"></i>
                          Also available in your app's environment variables
                        </small>
                      </div>
                    <% end %>

                    <!-- Redis URL -->
                    <% if @database_configuration.redis_enabled? && @database_configuration.redis_url.present? %>
                      <div class="mb-0">
                        <label class="form-label mb-1">
                          <i class="fas fa-memory text-success me-1"></i>
                          <strong><%= @database_configuration.redis_environment_variable_name %></strong>
                        </label>
                        <div class="input-group">
                          <input type="text"
                                 class="form-control font-monospace small"
                                 id="redis-url-input"
                                 value="<%= @database_configuration.redis_url %>"
                                 readonly>
                          <button class="btn btn-outline-secondary"
                                  type="button"
                                  onclick="copyFieldToClipboard('redis-url-input', this)"
                                  title="Copy to clipboard">
                            <i class="fas fa-copy"></i>
                          </button>
                        </div>
                        <small class="text-muted">
                          <i class="fas fa-check text-success me-1"></i>
                          Also available in your app's environment variables
                        </small>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>

            <!-- Submit Button -->
            <div class="row">
              <div class="col-12">
                <div class="d-flex gap-2 align-items-center">
                  <button type="submit" class="btn btn-primary" id="database-submit-btn">
                    <i class="fas fa-save me-2"></i>Configure Database
                  </button>
                  <%= link_to "Cancel", @deployment, class: "btn btn-secondary" %>

                  <div class="ms-auto">
                    <small class="text-muted">
                      <i class="fas fa-info-circle me-1"></i>
                      Process may take 5-10 minutes
                    </small>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Information Sidebar -->
    <div class="col-md-4">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>Database Status
          </h6>
        </div>
        <div class="card-body">
          <% if @database_configuration.persisted? %>
            <div class="mb-3">
              <h6 class="text-muted">Primary Database</h6>
              <div class="d-flex align-items-center">
                <i class="fas fa-database text-primary me-2"></i>
                <div class="flex-grow-1">
                  <strong><%= @database_configuration.display_name %></strong>
                  <br><small class="text-muted"><%= @database_configuration.database_name %></small>
                </div>
                <span class="badge <%= @database_configuration.status_class %>">
                  <%= @database_configuration.status_text %>
                </span>
              </div>
            </div>

            <% if @database_configuration.redis_enabled? %>
              <div class="mb-3">
                <h6 class="text-muted">Redis Cache</h6>
                <div class="d-flex align-items-center">
                  <i class="fas fa-memory text-success me-2"></i>
                  <div class="flex-grow-1">
                    <strong>Redis</strong>
                    <br><small class="text-muted"><%= @database_configuration.redis_name %></small>
                  </div>
                  <span class="badge bg-success">Enabled</span>
                </div>
              </div>
            <% end %>

            <% if @database_configuration.configured? %>
              <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Ready:</strong> Database is configured and available to your application.
              </div>
            <% elsif @database_configuration.error_message.present? %>
              <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Error:</strong> <%= @database_configuration.error_message %>
              </div>
            <% end %>

            <% if @database_configuration.can_be_deleted? %>
              <div class="mt-3">
                <%= form_with url: delete_database_configuration_deployment_path(@deployment), method: :delete, local: true, id: "simple-delete-form", class: "d-inline" do |form| %>
                  <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmDeletion(event)">
                    <i class="fas fa-trash me-2"></i>Delete Database Configuration
                  </button>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-3">
              <i class="fas fa-database fa-2x text-muted mb-2"></i>
              <p class="text-muted mb-0">No database configured</p>
              <small class="text-muted">Configure a database to get started</small>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-server me-2"></i>Deployment Info
          </h6>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <h6 class="text-muted">Dokku App Name</h6>
            <code class="text-info"><%= @deployment.dokku_app_name %></code>
          </div>

          <div class="mb-3">
            <h6 class="text-muted">Target Server</h6>
            <div class="d-flex align-items-center">
              <i class="fas fa-server text-secondary me-2"></i>
              <%= @deployment.server_name %>
            </div>
            <small class="text-muted"><%= @deployment.server.ip %></small>
          </div>
        </div>
      </div>

      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-lightbulb me-2"></i>Database Guide
          </h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">When you configure a database, Vantage will:</p>
          <ul class="list-unstyled mb-0">
            <li class="mb-2"><i class="fas fa-plug text-primary me-2"></i>Install the Dokku plugin on the server</li>
            <li class="mb-2"><i class="fas fa-database text-primary me-2"></i>Create a dedicated database instance</li>
            <li class="mb-2"><i class="fas fa-link text-primary me-2"></i>Link it to your app automatically</li>
            <li class="mb-0"><i class="fas fa-key text-primary me-2"></i>Set <code>DATABASE_URL</code> in your environment</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form      = document.getElementById('database-form');
  const submitBtn = document.getElementById('database-submit-btn');

  if (!form || !submitBtn) return;

  const submitBtnClone = submitBtn.cloneNode(true);

  function setBtnContent(btn, markup) {
    btn.replaceChildren();
    btn.insertAdjacentHTML('afterbegin', markup);
  }

  function resetSubmitBtn() {
    submitBtn.disabled = false;
    submitBtn.replaceChildren();
    submitBtn.append(...submitBtnClone.cloneNode(true).childNodes);
  }

  // ---- Form submit ----

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    submitBtn.disabled = true;
    setBtnContent(submitBtn, '<i class="fas fa-spinner fa-spin me-2"></i>Starting...');

    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        window.dispatchEvent(new CustomEvent('live-console:start', {
          detail: {
            id: 'db-config-<%= @deployment.uuid %>',
            label: 'Configuring database (<%= j @deployment.name %>)',
            channelName: 'DatabaseConfigurationChannel',
            channelParams: { deployment_uuid: '<%= @deployment.uuid %>' },
            onComplete: function({ success }) {
              resetSubmitBtn();
              if (success) setTimeout(() => window.location.reload(), 2000);
            }
          }
        }));
      } else {
        showToast('error', data.message || 'Failed to start configuration', 'Error');
        resetSubmitBtn();
      }
    })
    .catch(err => {
      console.error(err);
      showToast('error', 'An unexpected error occurred', 'Error');
      resetSubmitBtn();
    });
  });

  // ---- Deletion confirmation ----

  window.confirmDeletion = function(event) {
    event.preventDefault();
    window.appConfirm({
      title: 'Delete Database Configuration',
      bodyHtml: 'This will permanently delete the database configuration and all associated data. This action cannot be undone.',
      confirmLabel: 'Delete',
      danger: true
    }).then(ok => {
      if (ok) document.getElementById('simple-delete-form').submit();
    });
  };

  // ---- Copy field to clipboard ----

  window.copyFieldToClipboard = function(inputId, btn) {
    const input = document.getElementById(inputId);
    if (!input) return;
    navigator.clipboard.writeText(input.value).then(() => {
      const icon = btn.querySelector('i');
      if (icon) {
        icon.className = 'fas fa-check text-success';
        setTimeout(() => { icon.className = 'fas fa-copy'; }, 2000);
      }
    }).catch(() => {
      input.select();
      document.execCommand('copy');
    });
  };

  // ---- Toast helper ----

  function showToast(type, message, title) {
    const colorMap = { success: 'success', error: 'danger', warning: 'warning', info: 'primary' };
    const iconMap  = { success: 'fas fa-check-circle', error: 'fas fa-exclamation-circle', warning: 'fas fa-exclamation-triangle', info: 'fas fa-info-circle' };
    const color = colorMap[type] || 'primary';
    const icon  = iconMap[type]  || 'fas fa-info-circle';
    const time  = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const id    = 'toast-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);

    const toastEl = document.createElement('div');
    toastEl.id        = id;
    toastEl.className = 'toast fade show';
    toastEl.setAttribute('role', 'alert');
    toastEl.setAttribute('aria-live', 'assertive');
    toastEl.setAttribute('aria-atomic', 'true');
    toastEl.setAttribute('data-mdb-autohide', 'true');
    toastEl.setAttribute('data-mdb-delay', type === 'success' ? '6000' : '8000');

    const header = document.createElement('div');
    header.className = 'toast-header bg-' + color + ' text-white';

    const hIcon = document.createElement('i');
    hIcon.className = icon + ' me-2';
    const hTitle = document.createElement('strong');
    hTitle.className = 'me-auto';
    hTitle.textContent = title;
    const hTime = document.createElement('small');
    hTime.className = 'text-white-50';
    hTime.textContent = time;
    const hClose = document.createElement('button');
    hClose.type = 'button';
    hClose.className = 'btn-close btn-close-white ms-2';
    hClose.setAttribute('data-mdb-dismiss', 'toast');
    hClose.setAttribute('aria-label', 'Close');
    header.append(hIcon, hTitle, hTime, hClose);

    const body = document.createElement('div');
    body.className = 'toast-body bg-' + color + ' bg-opacity-10 border-' + color + ' border-start border-4';

    const bodyRow = document.createElement('div');
    bodyRow.className = 'd-flex align-items-start';
    const bIcon = document.createElement('i');
    bIcon.className = icon + ' text-' + color + ' me-3 mt-1';
    const bText = document.createElement('div');
    bText.className = 'flex-grow-1';
    bText.textContent = message;
    bodyRow.append(bIcon, bText);
    body.appendChild(bodyRow);

    toastEl.append(header, body);

    const container = document.getElementById('toast-container') || document.querySelector('.toast-container') || document.body;
    container.insertAdjacentElement('afterbegin', toastEl);

    toastEl.style.transform  = 'translateX(100%)';
    toastEl.style.transition = 'transform 0.3s ease-in-out';
    setTimeout(() => { toastEl.style.transform = 'translateX(0)'; }, 10);

    const toast = new mdb.Toast(toastEl);
    toast.show();
    toastEl.addEventListener('hidden.mdb.toast', () => toastEl.remove());
  }
});
</script>

<style>
.text-gray-800 { color: #5a5c69 !important; }
.card { box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important; }
</style>
