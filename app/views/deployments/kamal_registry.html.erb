<% content_for :title, "Registry Configuration — #{@deployment.name}" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-key me-2 text-info"></i>
            Docker Registry
          </h1>
          <p class="text-muted mb-0"><%= @deployment.name %></p>
        </div>
        <div class="d-flex gap-2">
          <%= link_to kamal_configuration_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Kamal Config
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-7">
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-box me-2"></i>Registry Credentials
          </h6>
        </div>
        <div class="card-body">
          <div class="alert alert-info mb-4">
            <i class="fas fa-info-circle me-2"></i>
            Credentials are encrypted at rest and never shown after saving.
            They are only used when Vantage runs <code>kamal deploy</code>.
          </div>

          <%= form_with model: @registry,
                url: update_kamal_registry_deployment_path(@deployment),
                method: :patch, local: true do |form| %>

            <div class="mb-3">
              <%= form.label :registry_server, "Registry Server", class: "form-label" %>
              <% common = KamalRegistry::COMMON_REGISTRIES %>
              <div class="input-group">
                <%= form.select :registry_server,
                      (common + [ "Custom..." ]).map { |r| [r, r] },
                      { selected: common.include?(@registry.registry_server) ? @registry.registry_server : "Custom..." },
                      { class: "form-select", id: "registry_server_select" } %>
                <%= form.text_field :registry_server,
                      value: @registry.registry_server,
                      class: "form-control #{'d-none' if common.include?(@registry.registry_server)}",
                      id: "registry_server_custom",
                      placeholder: "registry.example.com" %>
              </div>
              <div class="form-text">Choose a common registry or enter a custom address.</div>
            </div>

            <div class="mb-3">
              <%= form.label :username, "Username", class: "form-label" %>
              <%= form.text_field :username,
                    class: "form-control #{'is-invalid' if @registry.errors[:username].any?}",
                    autocomplete: "off" %>
              <% if @registry.errors[:username].any? %>
                <div class="invalid-feedback"><%= @registry.errors[:username].first %></div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= form.label :password, "Password / Personal Access Token", class: "form-label" %>
              <div class="input-group">
                <%= form.password_field :password,
                      class: "form-control #{'is-invalid' if @registry.errors[:password].any?}",
                      value: @registry.persisted? ? "••••••••" : "",
                      id: "registry_password",
                      autocomplete: "new-password" %>
                <button class="btn btn-outline-secondary" type="button"
                        onclick="togglePassword('registry_password', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
              <% if @registry.errors[:password].any? %>
                <div class="invalid-feedback d-block"><%= @registry.errors[:password].first %></div>
              <% end %>
              <div class="form-text">
                <% if @registry.persisted? %>
                  Leave as-is to keep the current password, or type a new one to replace it.
                <% else %>
                  For GitHub Container Registry, use a Personal Access Token with <code>write:packages</code>.
                <% end %>
              </div>
            </div>

            <% if @registry.persisted? && @kamal_config.service_name.present? %>
              <div class="alert alert-secondary mb-3">
                <i class="fas fa-tag me-2"></i>
                <strong>Image will be:</strong>
                <code><%= @registry.image_for(@kamal_config.service_name) %></code>
              </div>
            <% end %>

            <div class="d-flex gap-2">
              <%= form.submit "Save Registry Credentials", class: "btn btn-primary" %>
              <% if @registry.persisted? %>
                <button type="button" class="btn btn-outline-info" id="test-registry-btn"
                        onclick="testRegistry()">
                  <i class="fas fa-plug me-2"></i>Test Connection
                </button>
              <% end %>
              <%= link_to "Cancel", kamal_configuration_deployment_path(@deployment), class: "btn btn-secondary" %>
            </div>

          <% end %>

          <!-- Test result (Turbo frame target) -->
          <div id="registry-test-result" class="mt-3"></div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-question-circle me-2"></i>Common Registries
          </h6>
        </div>
        <div class="card-body">
          <dl class="small mb-0">
            <dt>GitHub Container Registry</dt>
            <dd class="text-muted">
              Server: <code>ghcr.io</code><br>
              Username: your GitHub username<br>
              Token: PAT with <code>write:packages</code>
            </dd>
            <dt>Docker Hub</dt>
            <dd class="text-muted">
              Server: <code>docker.io</code><br>
              Username: your Docker Hub username<br>
              Token: Access token from Docker Hub settings
            </dd>
            <dt>GitLab Registry</dt>
            <dd class="text-muted mb-0">
              Server: <code>registry.gitlab.com</code><br>
              Username: your GitLab username<br>
              Token: PAT with <code>read_registry</code> + <code>write_registry</code>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function togglePassword(fieldId, btn) {
    const field = document.getElementById(fieldId);
    if (field.type === "password") {
      field.type = "text";
      btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
    } else {
      field.type = "password";
      btn.innerHTML = '<i class="fas fa-eye"></i>';
    }
  }

  function testRegistry() {
    const btn = document.getElementById("test-registry-btn");
    const result = document.getElementById("registry-test-result");
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Testing...';

    fetch("<%= test_kamal_registry_deployment_path(@deployment) %>", {
      method: "POST",
      headers: { "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content }
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        result.innerHTML = '<div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>' + data.message + '</div>';
      } else {
        result.innerHTML = '<div class="alert alert-danger"><i class="fas fa-times-circle me-2"></i>' + (data.error || "Connection failed") + '</div>';
      }
    })
    .catch(() => {
      result.innerHTML = '<div class="alert alert-danger">Request failed</div>';
    })
    .finally(() => {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-plug me-2"></i>Test Connection';
    });
  }

  // Registry server dropdown — show custom input when "Custom..." selected
  document.addEventListener("turbo:load", function () {
    const select = document.getElementById("registry_server_select");
    const custom = document.getElementById("registry_server_custom");
    if (!select) return;

    select.addEventListener("change", function () {
      if (this.value === "Custom...") {
        custom.classList.remove("d-none");
        custom.required = true;
      } else {
        custom.classList.add("d-none");
        custom.required = false;
        custom.value = this.value;
      }
    });
  });
</script>
