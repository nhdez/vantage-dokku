<% content_for :title, "Registry Configuration — #{@deployment.name}" %>

<div class="container-fluid">
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-key me-2 text-info"></i>Docker Registry
          </h1>
          <p class="text-muted mb-0"><%= @deployment.name %></p>
        </div>
        <%= link_to kamal_configuration_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
          <i class="fas fa-arrow-left me-2"></i>Back to Kamal Config
        <% end %>
      </div>
    </div>
  </div>

  <!-- Option picker -->
  <div class="row mb-4">
    <div class="col">
      <div class="card shadow">
        <div class="card-body py-3">
          <p class="mb-2 fw-semibold">How do you want to store Docker images?</p>
          <div class="d-flex gap-3 flex-wrap">
            <div class="form-check">
              <input class="form-check-input" type="radio" name="registry_mode" id="mode_external"
                     value="external" <%= "checked" unless @registry.self_hosted? %> onchange="switchMode(this.value)">
              <label class="form-check-label" for="mode_external">
                <strong>External registry</strong>
                <span class="text-muted small d-block">GitHub, Docker Hub, GitLab — free accounts available</span>
              </label>
            </div>
            <div class="form-check ms-4">
              <input class="form-check-input" type="radio" name="registry_mode" id="mode_selfhosted"
                     value="selfhosted" <%= "checked" if @registry.self_hosted? %> onchange="switchMode(this.value)">
              <label class="form-check-label" for="mode_selfhosted">
                <strong>Self-hosted on your server</strong>
                <span class="text-muted small d-block">No external account — Vantage runs a private registry container</span>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-7">

      <!-- External registry form -->
      <div id="external-panel" class="<%= 'd-none' if @registry.self_hosted? %>">
        <div class="card shadow">
          <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-cloud me-2"></i>External Registry Credentials
            </h6>
          </div>
          <div class="card-body">
            <div class="alert alert-info mb-4">
              <i class="fas fa-info-circle me-2"></i>
              Credentials are encrypted at rest and never shown after saving.
              They are only used when Vantage runs <code>kamal deploy</code>.
            </div>

            <%= form_with model: @registry,
                  url: update_kamal_registry_deployment_path(@deployment),
                  method: :patch, local: true do |form| %>

              <%= form.hidden_field :self_hosted, value: "0" %>

              <div class="mb-3">
                <%= form.label :registry_server, "Registry Server", class: "form-label" %>
                <% common = KamalRegistry::COMMON_REGISTRIES %>
                <div class="input-group">
                  <%= form.select :registry_server,
                        (common + [ "Custom..." ]).map { |r| [r, r] },
                        { selected: common.include?(@registry.registry_server) ? @registry.registry_server : "Custom..." },
                        { class: "form-select", id: "registry_server_select" } %>
                  <%= form.text_field :registry_server,
                        value: @registry.registry_server,
                        class: "form-control #{'d-none' if common.include?(@registry.registry_server)}",
                        id: "registry_server_custom",
                        placeholder: "registry.example.com" %>
                </div>
              </div>

              <div class="mb-3">
                <%= form.label :username, "Username", class: "form-label" %>
                <%= form.text_field :username,
                      class: "form-control #{'is-invalid' if @registry.errors[:username].any?}",
                      autocomplete: "off" %>
                <% if @registry.errors[:username].any? %>
                  <div class="invalid-feedback"><%= @registry.errors[:username].first %></div>
                <% end %>
              </div>

              <div class="mb-3">
                <%= form.label :password, "Password / Personal Access Token", class: "form-label" %>
                <div class="input-group">
                  <%= form.password_field :password,
                        class: "form-control",
                        value: @registry.persisted? && !@registry.self_hosted? ? "••••••••" : "",
                        id: "registry_password",
                        autocomplete: "new-password" %>
                  <button class="btn btn-outline-secondary" type="button"
                          onclick="togglePassword('registry_password', this)">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
                <div class="form-text">
                  <% if @registry.persisted? && !@registry.self_hosted? %>
                    Leave as-is to keep the current password, or type a new one to replace it.
                  <% else %>
                    For GitHub Container Registry, use a PAT with <code>write:packages</code>.
                  <% end %>
                </div>
              </div>

              <% if @registry.persisted? && !@registry.self_hosted? && @kamal_config.service_name.present? %>
                <div class="alert alert-secondary mb-3">
                  <i class="fas fa-tag me-2"></i>
                  <strong>Image will be:</strong>
                  <code><%= @registry.image_for(@kamal_config.service_name) %></code>
                </div>
              <% end %>

              <div class="d-flex gap-2">
                <%= form.submit "Save Registry Credentials", class: "btn btn-primary" %>
                <% if @registry.persisted? && !@registry.self_hosted? %>
                  <button type="button" class="btn btn-outline-info" id="test-registry-btn"
                          onclick="testRegistry()">
                    <i class="fas fa-plug me-2"></i>Test Connection
                  </button>
                <% end %>
                <%= link_to "Cancel", kamal_configuration_deployment_path(@deployment), class: "btn btn-secondary" %>
              </div>
            <% end %>

            <div id="registry-test-result" class="mt-3"></div>
          </div>
        </div>
      </div>

      <!-- Self-hosted panel -->
      <div id="selfhosted-panel" class="<%= 'd-none' unless @registry.self_hosted? %>">
        <div class="card shadow">
          <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-success">
              <i class="fas fa-server me-2"></i>Self-Hosted Registry
              <% if @registry.self_hosted? %>
                <span class="badge bg-success ms-2">Active</span>
              <% end %>
            </h6>
          </div>
          <div class="card-body">
            <% if @registry.self_hosted? %>
              <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Self-hosted registry is configured</strong> at
                <code><%= @registry.registry_server %></code>.<br>
                A <code>registry:2</code> accessory has been added — go to
                <%= link_to "Accessories", kamal_accessories_deployment_path(@deployment), class: "alert-link" %>
                and <strong>Boot</strong> it to start the container.
              </div>
              <div class="mb-3">
                <strong>Registry address:</strong> <code><%= @registry.registry_server %></code><br>
                <strong>Credentials:</strong> auto-generated and encrypted (not shown)
              </div>
              <% if @kamal_config.service_name.present? %>
                <div class="alert alert-secondary">
                  <i class="fas fa-tag me-2"></i>
                  <strong>Image will be:</strong>
                  <code><%= @registry.image_for(@kamal_config.service_name) %></code>
                </div>
              <% end %>
              <%= button_to "Re-provision (rotate credentials)", provision_self_hosted_registry_deployment_path(@deployment),
                    method: :post,
                    class: "btn btn-outline-warning btn-sm",
                    data: { confirm: "This will rotate the registry credentials and update all server configs. Continue?" } %>
            <% else %>
              <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                <strong>How it works:</strong> Vantage will run the official
                <code>registry:2</code> Docker image as an accessory on your primary web server.
                No Docker Hub account needed. Images are stored on your own server.
              </div>

              <ul class="mb-4">
                <li>Generates secure credentials automatically</li>
                <li>Configures Docker on all assigned servers to trust the registry</li>
                <li>Adds a <code>registry</code> accessory you can Boot from the Accessories page</li>
                <li>Requires at least one web server assigned in Kamal Configuration</li>
              </ul>

              <%= button_to "Provision Self-Hosted Registry", provision_self_hosted_registry_deployment_path(@deployment),
                    method: :post,
                    class: "btn btn-success",
                    data: { confirm: "This will create a registry accessory on your primary server and configure Docker on all assigned servers. Continue?" } %>
            <% end %>
          </div>
        </div>
      </div>

    </div>

    <!-- Sidebar -->
    <div class="col-lg-5">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-question-circle me-2"></i>Choosing a Registry
          </h6>
        </div>
        <div class="card-body small">
          <dl class="mb-0">
            <dt><i class="fab fa-github me-1"></i> GitHub Container Registry — recommended</dt>
            <dd class="text-muted mb-3">
              Free with any GitHub account. Create a PAT at
              <strong>Settings → Developer settings → Personal access tokens</strong>
              with <code>write:packages</code> scope.<br>
              Server: <code>ghcr.io</code>
            </dd>

            <dt><i class="fab fa-docker me-1"></i> Docker Hub</dt>
            <dd class="text-muted mb-3">
              Free tier available (with pull rate limits). Create an Access Token under
              <strong>Account Settings → Security</strong>.<br>
              Server: <code>docker.io</code>
            </dd>

            <dt><i class="fab fa-gitlab me-1"></i> GitLab Registry</dt>
            <dd class="text-muted mb-3">
              Free with any GitLab account. PAT needs
              <code>read_registry</code> + <code>write_registry</code>.<br>
              Server: <code>registry.gitlab.com</code>
            </dd>

            <dt><i class="fas fa-server me-1"></i> Self-hosted</dt>
            <dd class="text-muted mb-0">
              No external account. Runs on your own server.
              Images stay private by default. Requires one of your servers
              to have port 5000 accessible from the Vantage host.
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function switchMode(mode) {
    const external = document.getElementById("external-panel");
    const selfhosted = document.getElementById("selfhosted-panel");
    if (mode === "selfhosted") {
      external.classList.add("d-none");
      selfhosted.classList.remove("d-none");
    } else {
      selfhosted.classList.add("d-none");
      external.classList.remove("d-none");
    }
  }

  function togglePassword(fieldId, btn) {
    const field = document.getElementById(fieldId);
    if (field.type === "password") {
      field.type = "text";
      btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
    } else {
      field.type = "password";
      btn.innerHTML = '<i class="fas fa-eye"></i>';
    }
  }

  function testRegistry() {
    const btn = document.getElementById("test-registry-btn");
    const result = document.getElementById("registry-test-result");
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Testing...';

    fetch("<%= test_kamal_registry_deployment_path(@deployment) %>", {
      method: "POST",
      headers: { "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content }
    })
    .then(r => r.json())
    .then(data => {
      result.innerHTML = data.success
        ? '<div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>' + data.message + '</div>'
        : '<div class="alert alert-danger"><i class="fas fa-times-circle me-2"></i>' + (data.error || "Connection failed") + '</div>';
    })
    .catch(() => { result.innerHTML = '<div class="alert alert-danger">Request failed</div>'; })
    .finally(() => {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-plug me-2"></i>Test Connection';
    });
  }

  document.addEventListener("turbo:load", function () {
    const select = document.getElementById("registry_server_select");
    const custom = document.getElementById("registry_server_custom");
    if (!select) return;

    select.addEventListener("change", function () {
      if (this.value === "Custom...") {
        custom.classList.remove("d-none");
        custom.required = true;
      } else {
        custom.classList.add("d-none");
        custom.required = false;
        custom.value = this.value;
      }
    });
  });
</script>
