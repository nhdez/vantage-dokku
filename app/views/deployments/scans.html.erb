<% content_for :title, "Vulnerability Scans - #{@deployment.name}" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-shield-alt me-2 text-danger"></i>
            Vulnerability Scans
          </h1>
          <p class="text-muted mb-0">
            Security scan results for <%= @deployment.name %>
          </p>
        </div>
        <div>
          <%= link_to @deployment, class: "btn btn-outline-secondary me-2" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Deployment
          <% end %>
          <%= button_tag class: "btn btn-primary", id: "trigger-scan-btn" do %>
            <i class="fas fa-play me-2"></i>Run Scan Now
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Scan Summary -->
  <% if @latest_scan.present? %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="card shadow-lg border-0">
          <div class="card-header py-3 bg-gradient-primary text-white">
            <h6 class="m-0 font-weight-bold">
              <i class="fas fa-chart-line me-2"></i>Latest Scan Results
            </h6>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-3">
                <div class="stat-card border-0 shadow-sm rounded p-3 h-100 bg-primary bg-opacity-10">
                  <div class="d-flex align-items-center">
                    <div class="stat-icon bg-primary bg-opacity-25 rounded-circle p-3 me-3">
                      <i class="fas fa-cube text-primary fs-4"></i>
                    </div>
                    <div>
                      <div class="text-muted small mb-1">Total Packages</div>
                      <div class="h3 mb-0 fw-bold text-primary"><%= @latest_scan.total_packages %></div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-3">
                <div class="stat-card border-0 shadow-sm rounded p-3 h-100 bg-<%= @latest_scan.vulnerabilities_found > 0 ? 'danger' : 'success' %> bg-opacity-10">
                  <div class="d-flex align-items-center">
                    <div class="stat-icon bg-<%= @latest_scan.vulnerabilities_found > 0 ? 'danger' : 'success' %> bg-opacity-25 rounded-circle p-3 me-3">
                      <i class="fas fa-<%= @latest_scan.vulnerabilities_found > 0 ? 'exclamation-triangle' : 'shield-check' %> text-<%= @latest_scan.vulnerabilities_found > 0 ? 'danger' : 'success' %> fs-4"></i>
                    </div>
                    <div>
                      <div class="text-muted small mb-1">Vulnerabilities</div>
                      <div class="h3 mb-0 fw-bold text-<%= @latest_scan.vulnerabilities_found > 0 ? 'danger' : 'success' %>">
                        <%= @latest_scan.vulnerabilities_found %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-3">
                <div class="stat-card border-0 shadow-sm rounded p-3 h-100 bg-info bg-opacity-10">
                  <div class="d-flex align-items-center">
                    <div class="stat-icon bg-info bg-opacity-25 rounded-circle p-3 me-3">
                      <i class="fas fa-tasks text-info fs-4"></i>
                    </div>
                    <div>
                      <div class="text-muted small mb-1">Status</div>
                      <div>
                        <span class="badge rounded-pill bg-<%= @latest_scan.severity_badge_class %> fs-6 px-3">
                          <%= @latest_scan.status.titleize %>
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-3">
                <div class="stat-card border-0 shadow-sm rounded p-3 h-100 bg-secondary bg-opacity-10">
                  <div class="d-flex align-items-center">
                    <div class="stat-icon bg-secondary bg-opacity-25 rounded-circle p-3 me-3">
                      <i class="far fa-clock text-secondary fs-4"></i>
                    </div>
                    <div>
                      <div class="text-muted small mb-1">Scanned At</div>
                      <div class="small fw-medium">
                        <%= @latest_scan.completed_at&.strftime("%b %d, %H:%M") || "In Progress" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <% if @latest_scan.vulnerabilities_found > 0 %>
              <div class="alert alert-<%= @latest_scan.severity_badge_class %> border-0 shadow-sm mt-4 mb-3">
                <div class="d-flex align-items-center">
                  <i class="fas fa-exclamation-triangle fs-4 me-3"></i>
                  <div>
                    <strong>Security Alert:</strong> <%= @latest_scan.severity_summary %>
                  </div>
                </div>
              </div>

              <div class="row g-3 mt-2">
                <% if @latest_scan.critical_count > 0 %>
                  <div class="col-6 col-md-3">
                    <div class="severity-badge-card bg-danger bg-opacity-10 border border-danger rounded p-3 text-center">
                      <i class="fas fa-exclamation-circle text-danger fs-3 mb-2"></i>
                      <div class="h4 mb-1 text-danger fw-bold"><%= @latest_scan.critical_count %></div>
                      <div class="small text-danger fw-medium">Critical</div>
                    </div>
                  </div>
                <% end %>
                <% if @latest_scan.high_count > 0 %>
                  <div class="col-6 col-md-3">
                    <div class="severity-badge-card bg-warning bg-opacity-10 border border-warning rounded p-3 text-center">
                      <i class="fas fa-exclamation-triangle text-warning fs-3 mb-2"></i>
                      <div class="h4 mb-1 text-warning fw-bold"><%= @latest_scan.high_count %></div>
                      <div class="small text-warning fw-medium">High</div>
                    </div>
                  </div>
                <% end %>
                <% if @latest_scan.medium_count > 0 %>
                  <div class="col-6 col-md-3">
                    <div class="severity-badge-card bg-info bg-opacity-10 border border-info rounded p-3 text-center">
                      <i class="fas fa-info-circle text-info fs-3 mb-2"></i>
                      <div class="h4 mb-1 text-info fw-bold"><%= @latest_scan.medium_count %></div>
                      <div class="small text-info fw-medium">Medium</div>
                    </div>
                  </div>
                <% end %>
                <% if @latest_scan.low_count > 0 %>
                  <div class="col-6 col-md-3">
                    <div class="severity-badge-card bg-secondary bg-opacity-10 border border-secondary rounded p-3 text-center">
                      <i class="fas fa-minus-circle text-secondary fs-3 mb-2"></i>
                      <div class="h4 mb-1 text-secondary fw-bold"><%= @latest_scan.low_count %></div>
                      <div class="small text-secondary fw-medium">Low</div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="alert alert-success border-0 shadow-sm mt-4 mb-0">
                <div class="d-flex align-items-center">
                  <i class="fas fa-check-circle fs-4 me-3"></i>
                  <div>
                    <strong>All Clear!</strong> No vulnerabilities were found in this deployment.
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="alert alert-info border-0 shadow-sm">
          <div class="d-flex align-items-center">
            <i class="fas fa-info-circle fs-4 me-3"></i>
            <div>
              <strong>No scans yet.</strong> Click "Run Scan Now" to start your first vulnerability scan.
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Vulnerabilities List -->
  <% if @latest_scan.present? && @latest_scan.vulnerabilities.any? %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="card shadow">
          <div class="card-header py-3 bg-light">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-list me-2"></i>Vulnerabilities Details
            </h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Severity</th>
                    <th>CVE ID</th>
                    <th>Package</th>
                    <th>Current Version</th>
                    <th>Fixed Version</th>
                    <th>CVSS Score</th>
                    <th>Source</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @latest_scan.vulnerabilities.by_severity.each do |vuln| %>
                    <tr>
                      <td>
                        <span class="badge bg-<%= vuln.severity_badge_class %>">
                          <%= vuln.severity %>
                        </span>
                      </td>
                      <td>
                        <code><%= vuln.osv_id %></code>
                      </td>
                      <td>
                        <strong><%= vuln.package_name %></strong>
                        <br>
                        <small class="text-muted"><%= vuln.ecosystem %></small>
                      </td>
                      <td><code><%= vuln.current_version %></code></td>
                      <td>
                        <% if vuln.fixable? %>
                          <code class="text-success"><%= vuln.fixed_version %></code>
                        <% else %>
                          <span class="text-muted">Not available</span>
                        <% end %>
                      </td>
                      <td>
                        <% if vuln.cvss_score > 0 %>
                          <%= vuln.cvss_score %>
                        <% else %>
                          <span class="text-muted">N/A</span>
                        <% end %>
                      </td>
                      <td><small><%= vuln.source_file %></small></td>
                      <td>
                        <% if vuln.osv_url.present? %>
                          <%= link_to vuln.osv_url, target: "_blank", class: "btn btn-sm btn-outline-primary" do %>
                            <i class="fas fa-external-link-alt me-1"></i>Details
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Scan History -->
  <div class="row">
    <div class="col-lg-12">
      <div class="card shadow-lg border-0">
        <div class="card-header py-3 bg-gradient-primary text-white">
          <h6 class="m-0 font-weight-bold">
            <i class="fas fa-history me-2"></i>Scan History
          </h6>
        </div>
        <div class="card-body">
          <% if @vulnerability_scans.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0" id="scans-table">
                <thead class="table-light">
                  <tr>
                    <th class="border-0">Date</th>
                    <th class="border-0">Type</th>
                    <th class="border-0">Status</th>
                    <th class="border-0">Packages</th>
                    <th class="border-0">Vulnerabilities</th>
                    <th class="border-0">Severity</th>
                    <th class="border-0">Duration</th>
                    <th class="border-0 text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @vulnerability_scans.each_with_index do |scan, index| %>
                    <tr class="scan-row">
                      <td class="align-middle">
                        <span class="fw-medium"><%= scan.created_at.strftime("%b %d, %Y") %></span>
                        <br>
                        <small class="text-muted"><%= scan.created_at.strftime("%H:%M") %></small>
                      </td>
                      <td class="align-middle">
                        <span class="badge rounded-pill bg-<%= scan.scan_type == 'manual' ? 'primary' : 'info' %>">
                          <i class="fas fa-<%= scan.scan_type == 'manual' ? 'hand-pointer' : 'clock' %> me-1"></i>
                          <%= scan.scan_type.titleize %>
                        </span>
                      </td>
                      <td class="align-middle">
                        <span class="badge rounded-pill bg-<%= scan.severity_badge_class %>">
                          <%= scan.status.titleize %>
                        </span>
                      </td>
                      <td class="align-middle">
                        <span class="badge bg-light text-dark border">
                          <i class="fas fa-cube me-1"></i><%= scan.total_packages %>
                        </span>
                      </td>
                      <td class="align-middle">
                        <% if scan.vulnerabilities_found > 0 %>
                          <span class="badge bg-danger-subtle text-danger border border-danger fw-bold fs-6">
                            <i class="fas fa-exclamation-triangle me-1"></i><%= scan.vulnerabilities_found %>
                          </span>
                        <% else %>
                          <span class="badge bg-success-subtle text-success border border-success">
                            <i class="fas fa-check-circle me-1"></i>0
                          </span>
                        <% end %>
                      </td>
                      <td class="align-middle">
                        <% if scan.vulnerabilities_found > 0 %>
                          <small class="text-muted"><%= scan.severity_summary %></small>
                        <% else %>
                          <span class="text-muted"><i class="fas fa-shield-alt me-1"></i>Clean</span>
                        <% end %>
                      </td>
                      <td class="align-middle">
                        <% if scan.completed_at && scan.started_at %>
                          <i class="far fa-clock me-1 text-muted"></i>
                          <%= distance_of_time_in_words(scan.started_at, scan.completed_at) %>
                        <% else %>
                          <span class="text-muted">-</span>
                        <% end %>
                      </td>
                      <td class="align-middle text-end">
                        <%= link_to deployment_vulnerability_scan_path(@deployment, scan), class: "btn btn-sm btn-outline-primary" do %>
                          <i class="fas fa-eye me-1"></i>View Details
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
          <% else %>
            <div class="text-center py-5">
              <i class="fas fa-clipboard-list fa-4x text-muted mb-3"></i>
              <p class="text-muted">No scan history available yet.</p>
              <p class="text-muted small">Run your first scan to see results here.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const deploymentUuid = '<%= @deployment.uuid %>';
  const triggerScanBtn = document.getElementById('trigger-scan-btn');

  if (triggerScanBtn) {
    triggerScanBtn.addEventListener('click', function() {
      if (!confirm('This will scan this deployment for vulnerabilities. This may take a few minutes. Continue?')) {
        return;
      }

      const btn = this;
      const originalHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Starting scan...';

      fetch(`/deployments/${deploymentUuid}/trigger_scan`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Show success toast
          showToast('success', data.message + ' Refreshing in 3 seconds...', 'Scan Started');

          setTimeout(() => {
            location.reload();
          }, 3000);
        } else {
          showToast('error', data.message, 'Scan Error');
          btn.disabled = false;
          btn.innerHTML = originalHTML;
        }
      })
      .catch(error => {
        console.error('Error starting scan:', error);
        showToast('error', 'Failed to start scan. Please try again.', 'Scan Error');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      });
    });
  }

  // Helper function to show toast notifications
  function showToast(type, message, title) {
    // Create toast container if it doesn't exist
    let container = document.getElementById('toast-container');
    if (!container) {
      container = document.createElement('div');
      container.id = 'toast-container';
      container.className = 'toast-container position-fixed top-0 end-0 p-3';
      container.style.zIndex = '9999';
      document.body.appendChild(container);
    }

    const toastId = `toast-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    const iconMap = {
      success: 'fas fa-check-circle',
      error: 'fas fa-exclamation-circle',
      warning: 'fas fa-exclamation-triangle',
      info: 'fas fa-info-circle'
    };

    const colorMap = {
      success: 'success',
      error: 'danger',
      warning: 'warning',
      info: 'info'
    };

    const toastIcon = iconMap[type] || 'fas fa-info-circle';
    const toastColor = colorMap[type] || 'info';
    const now = new Date();
    const timeString = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    const toastHTML = `
      <div id="${toastId}" class="toast fade show" role="alert" aria-live="assertive" aria-atomic="true"
           data-mdb-autohide="true" data-mdb-delay="5000">
        <div class="toast-header bg-${toastColor} text-white">
          <i class="${toastIcon} me-2"></i>
          <strong class="me-auto">${title}</strong>
          <small class="text-white-50">${timeString}</small>
          <button type="button" class="btn-close btn-close-white ms-2" data-mdb-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body bg-${toastColor} bg-opacity-10 border-${toastColor} border-start border-4">
          <div class="d-flex align-items-start">
            <i class="${toastIcon} text-${toastColor} me-3 mt-1"></i>
            <div class="flex-grow-1">
              ${message}
            </div>
          </div>
        </div>
      </div>
    `;

    container.insertAdjacentHTML('afterbegin', toastHTML);

    const toastElement = document.getElementById(toastId);
    const toast = new mdb.Toast(toastElement);

    toastElement.addEventListener('hidden.mdb.toast', () => {
      toastElement.remove();
    });

    toastElement.style.transform = 'translateX(100%)';
    toastElement.style.transition = 'transform 0.3s ease-in-out';

    setTimeout(() => {
      toastElement.style.transform = 'translateX(0)';
    }, 10);
  }

});
</script>

<style>
.text-gray-800 {
  color: #5a5c69 !important;
}
.card {
  box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
}
.font-weight-bold {
  font-weight: 600;
}

/* Gradient header */
.bg-gradient-primary {
  background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
}

/* Table row hover */
.scan-row {
  transition: background-color 0.15s ease;
}
.scan-row:hover {
  background-color: rgba(78, 115, 223, 0.03);
}

/* Badge enhancements */
.badge.rounded-pill {
  padding: 0.5em 0.9em;
}

/* Better subtle backgrounds for Bootstrap 5.3+ */
.bg-danger-subtle {
  background-color: rgba(220, 53, 69, 0.1) !important;
}
.bg-success-subtle {
  background-color: rgba(25, 135, 84, 0.1) !important;
}

/* Monospace font for code */
.font-monospace {
  font-family: 'Courier New', Courier, monospace;
  font-size: 0.85em;
}

/* Table improvements */
#scans-table tbody tr {
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

#scans-table thead th {
  font-weight: 600;
  text-transform: uppercase;
  font-size: 0.85rem;
  color: #5a5c69;
  letter-spacing: 0.5px;
}

/* Stat cards */
.stat-card {
  transition: all 0.2s ease;
}
.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
}
.stat-icon {
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Severity badge cards */
.severity-badge-card {
  transition: all 0.2s ease;
}
.severity-badge-card:hover {
  transform: scale(1.05);
  box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.1);
}
</style>
