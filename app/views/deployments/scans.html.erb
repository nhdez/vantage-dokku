<% content_for :title, "Vulnerability Scans - #{@deployment.name}" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-shield-alt me-2 text-danger"></i>
            Vulnerability Scans
          </h1>
          <p class="text-muted mb-0">
            Security scan results for <%= @deployment.name %>
          </p>
        </div>
        <div>
          <%= link_to @deployment, class: "btn btn-outline-secondary me-2" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Deployment
          <% end %>
          <%= button_tag class: "btn btn-primary", id: "trigger-scan-btn" do %>
            <i class="fas fa-play me-2"></i>Run Scan Now
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Scan Summary -->
  <% if @latest_scan.present? %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="card shadow">
          <div class="card-header py-3 bg-light">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-chart-line me-2"></i>Latest Scan Results
            </h6>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-3 mb-3">
                <div class="border rounded p-3 text-center">
                  <div class="text-muted small mb-1">Total Packages</div>
                  <div class="h3 mb-0"><%= @latest_scan.total_packages %></div>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="border rounded p-3 text-center">
                  <div class="text-muted small mb-1">Vulnerabilities Found</div>
                  <div class="h3 mb-0 text-<%= @latest_scan.vulnerabilities_found > 0 ? 'danger' : 'success' %>">
                    <%= @latest_scan.vulnerabilities_found %>
                  </div>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="border rounded p-3 text-center">
                  <div class="text-muted small mb-1">Status</div>
                  <div>
                    <span class="badge bg-<%= @latest_scan.severity_badge_class %>">
                      <%= @latest_scan.status.titleize %>
                    </span>
                  </div>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="border rounded p-3 text-center">
                  <div class="text-muted small mb-1">Scanned At</div>
                  <div class="small">
                    <%= @latest_scan.completed_at&.strftime("%Y-%m-%d %H:%M") || "In Progress" %>
                  </div>
                </div>
              </div>
            </div>

            <% if @latest_scan.vulnerabilities_found > 0 %>
              <div class="alert alert-<%= @latest_scan.severity_badge_class %> mt-3">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Severity Breakdown:</strong> <%= @latest_scan.severity_summary %>
              </div>

              <div class="row mt-3">
                <div class="col-6 col-md-3 mb-2">
                  <div class="d-flex align-items-center">
                    <span class="badge bg-danger me-2">Critical</span>
                    <span><%= @latest_scan.critical_count %></span>
                  </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                  <div class="d-flex align-items-center">
                    <span class="badge bg-warning me-2">High</span>
                    <span><%= @latest_scan.high_count %></span>
                  </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                  <div class="d-flex align-items-center">
                    <span class="badge bg-info me-2">Medium</span>
                    <span><%= @latest_scan.medium_count %></span>
                  </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                  <div class="d-flex align-items-center">
                    <span class="badge bg-secondary me-2">Low</span>
                    <span><%= @latest_scan.low_count %></span>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="alert alert-success mt-3">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Great news!</strong> No vulnerabilities were found in this deployment.
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="alert alert-info">
          <i class="fas fa-info-circle me-2"></i>
          <strong>No scans yet.</strong> Click "Run Scan Now" to start your first vulnerability scan.
        </div>
      </div>
    </div>
  <% end %>

  <!-- Vulnerabilities List -->
  <% if @latest_scan.present? && @latest_scan.vulnerabilities.any? %>
    <div class="row mb-4">
      <div class="col-lg-12">
        <div class="card shadow">
          <div class="card-header py-3 bg-light">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-list me-2"></i>Vulnerabilities Details
            </h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Severity</th>
                    <th>CVE ID</th>
                    <th>Package</th>
                    <th>Current Version</th>
                    <th>Fixed Version</th>
                    <th>CVSS Score</th>
                    <th>Source</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @latest_scan.vulnerabilities.by_severity.each do |vuln| %>
                    <tr>
                      <td>
                        <span class="badge bg-<%= vuln.severity_badge_class %>">
                          <%= vuln.severity %>
                        </span>
                      </td>
                      <td>
                        <code><%= vuln.osv_id %></code>
                      </td>
                      <td>
                        <strong><%= vuln.package_name %></strong>
                        <br>
                        <small class="text-muted"><%= vuln.ecosystem %></small>
                      </td>
                      <td><code><%= vuln.current_version %></code></td>
                      <td>
                        <% if vuln.fixable? %>
                          <code class="text-success"><%= vuln.fixed_version %></code>
                        <% else %>
                          <span class="text-muted">Not available</span>
                        <% end %>
                      </td>
                      <td>
                        <% if vuln.cvss_score > 0 %>
                          <%= vuln.cvss_score %>
                        <% else %>
                          <span class="text-muted">N/A</span>
                        <% end %>
                      </td>
                      <td><small><%= vuln.source_file %></small></td>
                      <td>
                        <% if vuln.osv_url.present? %>
                          <%= link_to vuln.osv_url, target: "_blank", class: "btn btn-sm btn-outline-primary" do %>
                            <i class="fas fa-external-link-alt me-1"></i>Details
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Scan History -->
  <div class="row">
    <div class="col-lg-12">
      <div class="card shadow">
        <div class="card-header py-3 bg-light">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-history me-2"></i>Scan History
          </h6>
        </div>
        <div class="card-body">
          <% if @vulnerability_scans.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Packages</th>
                    <th>Vulnerabilities</th>
                    <th>Severity</th>
                    <th>Duration</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @vulnerability_scans.each do |scan| %>
                    <tr>
                      <td><%= scan.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                      <td>
                        <span class="badge bg-<%= scan.scan_type == 'manual' ? 'primary' : 'info' %>">
                          <%= scan.scan_type.titleize %>
                        </span>
                      </td>
                      <td>
                        <span class="badge bg-<%= scan.severity_badge_class %>">
                          <%= scan.status.titleize %>
                        </span>
                      </td>
                      <td><%= scan.total_packages %></td>
                      <td>
                        <span class="<%= scan.vulnerabilities_found > 0 ? 'text-danger fw-bold' : 'text-success' %>">
                          <%= scan.vulnerabilities_found %>
                        </span>
                      </td>
                      <td>
                        <% if scan.vulnerabilities_found > 0 %>
                          <small><%= scan.severity_summary %></small>
                        <% else %>
                          <span class="text-muted">None</span>
                        <% end %>
                      </td>
                      <td>
                        <% if scan.completed_at && scan.started_at %>
                          <%= distance_of_time_in_words(scan.started_at, scan.completed_at) %>
                        <% else %>
                          <span class="text-muted">-</span>
                        <% end %>
                      </td>
                      <td>
                        <%= link_to deployment_vulnerability_scan_path(@deployment, scan),
                                    class: "btn btn-sm btn-primary",
                                    data: { turbo: false } do %>
                          <i class="fas fa-eye me-1"></i>View
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
          <% else %>
            <div class="text-center py-4 text-muted">
              <i class="fas fa-inbox fa-3x mb-3"></i>
              <p>No scan history available yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  const deploymentUuid = '<%= @deployment.uuid %>';
  const triggerScanBtn = document.getElementById('trigger-scan-btn');

  if (triggerScanBtn) {
    triggerScanBtn.addEventListener('click', function() {
      if (!confirm('This will scan this deployment for vulnerabilities. This may take a few minutes. Continue?')) {
        return;
      }

      const btn = this;
      const originalHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Starting scan...';

      fetch(`/deployments/${deploymentUuid}/trigger_scan`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Show success toast
          showToast('success', data.message + ' Refreshing in 3 seconds...', 'Scan Started');

          setTimeout(() => {
            location.reload();
          }, 3000);
        } else {
          showToast('error', data.message, 'Scan Error');
          btn.disabled = false;
          btn.innerHTML = originalHTML;
        }
      })
      .catch(error => {
        console.error('Error starting scan:', error);
        showToast('error', 'Failed to start scan. Please try again.', 'Scan Error');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      });
    });
  }

  // Helper function to show toast notifications
  function showToast(type, message, title) {
    // Create toast container if it doesn't exist
    let container = document.getElementById('toast-container');
    if (!container) {
      container = document.createElement('div');
      container.id = 'toast-container';
      container.className = 'toast-container position-fixed top-0 end-0 p-3';
      container.style.zIndex = '9999';
      document.body.appendChild(container);
    }

    const toastId = `toast-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    const iconMap = {
      success: 'fas fa-check-circle',
      error: 'fas fa-exclamation-circle',
      warning: 'fas fa-exclamation-triangle',
      info: 'fas fa-info-circle'
    };

    const colorMap = {
      success: 'success',
      error: 'danger',
      warning: 'warning',
      info: 'info'
    };

    const toastIcon = iconMap[type] || 'fas fa-info-circle';
    const toastColor = colorMap[type] || 'info';
    const now = new Date();
    const timeString = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    const toastHTML = `
      <div id="${toastId}" class="toast fade show" role="alert" aria-live="assertive" aria-atomic="true"
           data-mdb-autohide="true" data-mdb-delay="5000">
        <div class="toast-header bg-${toastColor} text-white">
          <i class="${toastIcon} me-2"></i>
          <strong class="me-auto">${title}</strong>
          <small class="text-white-50">${timeString}</small>
          <button type="button" class="btn-close btn-close-white ms-2" data-mdb-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body bg-${toastColor} bg-opacity-10 border-${toastColor} border-start border-4">
          <div class="d-flex align-items-start">
            <i class="${toastIcon} text-${toastColor} me-3 mt-1"></i>
            <div class="flex-grow-1">
              ${message}
            </div>
          </div>
        </div>
      </div>
    `;

    container.insertAdjacentHTML('afterbegin', toastHTML);

    const toastElement = document.getElementById(toastId);
    const toast = new mdb.Toast(toastElement);

    toastElement.addEventListener('hidden.mdb.toast', () => {
      toastElement.remove();
    });

    toastElement.style.transform = 'translateX(100%)';
    toastElement.style.transition = 'transform 0.3s ease-in-out';

    setTimeout(() => {
      toastElement.style.transform = 'translateX(0)';
    }, 10);
  }

});
</script>

<style>
.text-gray-800 {
  color: #5a5c69 !important;
}
.card {
  box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
}
.font-weight-bold {
  font-weight: 600;
}
</style>
