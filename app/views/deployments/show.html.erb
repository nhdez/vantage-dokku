<% content_for :title, @deployment.name %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-rocket me-2 text-primary"></i>
            <%= @deployment.name %>
          </h1>
          <p class="text-muted mb-0">
            Dokku application: <code class="text-info"><%= @deployment.dokku_app_name %></code>
          </p>
        </div>
        <div>
          <%= link_to edit_deployment_path(@deployment), class: "btn btn-primary me-2" do %>
            <i class="fas fa-edit me-2"></i>Edit App
          <% end %>
          <%= link_to deployments_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Apps
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Application Information -->
    <div class="col-md-8">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>Application Information
          </h6>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Application Name</h6>
              <p class="h5 mb-0"><%= @deployment.name %></p>
            </div>
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Dokku App Name</h6>
              <p class="h5 mb-0">
                <code class="text-info fs-6"><%= @deployment.dokku_app_name %></code>
              </p>
            </div>
          </div>
          
          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Status</h6>
              <p class="h5 mb-0" id="deployment-status-badge">
                <span class="badge <%= @deployment.status_badge_class %> fs-6" id="status-badge">
                  <i class="<%= @deployment.status_icon %> me-1" id="status-icon"></i>
                  <span id="status-text"><%= @deployment.status_text %></span>
                </span>
              </p>
              <sup id="last-deployed-sup" <%= 'style="display:none"' unless @deployment.last_deployment_at.present? %>>
                <strong>Last deployed:</strong>
                <span id="last-deployed-text"><%= @deployment.last_deployment_at.present? ? "#{time_ago_in_words(@deployment.last_deployment_at)} ago" : "" %></span>
              </sup>
            </div>
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Target Server</h6>
              <p class="h5 mb-0">
                <div class="d-flex align-items-center">
                  <i class="fas fa-server text-secondary me-2"></i>
                  <%= link_to @deployment.server_name, @deployment.server, class: "text-decoration-none" %>
                  <% if @deployment.server.dokku_installed? %>
                    <span class="badge bg-success ms-2">Dokku Installed</span>
                  <% else %>
                    <span class="badge bg-warning text-dark ms-2">No Dokku</span>
                  <% end %>
                </div>
              </p>
            </div>
          </div>
          
          <% if @deployment.description.present? %>
            <div class="row">
              <div class="col-md-12 mb-3">
                <h6 class="text-muted">Description</h6>
                <p class="mb-0"><%= @deployment.description %></p>
              </div>
            </div>
          <% end %>

          <!-- Latest Vulnerability Scan -->
          <% if @latest_vulnerability_scan.present? %>
            <hr class="my-3">
            <div class="row">
              <div class="col-md-12">
                <h6 class="text-muted">
                  <i class="fas fa-shield-alt me-1"></i>Latest Vulnerability Scan
                </h6>
                <div class="d-flex align-items-center justify-content-between">
                  <div>
                    <% if @latest_vulnerability_scan.vulnerabilities_found > 0 %>
                      <span class="badge bg-<%= @latest_vulnerability_scan.severity_badge_class %> me-2">
                        <%= @latest_vulnerability_scan.vulnerabilities_found %>
                        <%= 'vulnerability'.pluralize(@latest_vulnerability_scan.vulnerabilities_found) %> found
                      </span>
                      <small class="text-muted"><%= @latest_vulnerability_scan.severity_summary %></small>
                    <% else %>
                      <span class="badge bg-success me-2">
                        <i class="fas fa-check-circle me-1"></i>No vulnerabilities
                      </span>
                    <% end %>
                    <br>
                    <small class="text-muted">
                      Scanned <%= time_ago_in_words(@latest_vulnerability_scan.created_at) %> ago
                    </small>
                  </div>
                  <div>
                    <%= link_to scans_deployment_path(@deployment), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="fas fa-list me-1"></i>View All Scans
                    <% end %>
                    <% if @latest_vulnerability_scan.vulnerabilities_found > 0 %>
                      <%= link_to deployment_vulnerability_scan_path(@deployment, @latest_vulnerability_scan), class: "btn btn-sm btn-primary ms-2" do %>
                        <i class="fas fa-eye me-1"></i>View Report
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Configuration Overview -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cog me-2"></i>Configuration Information
          </h6>
        </div>
        <div class="card-body">
          <div class="row">
            <!-- Git Repository -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-code-branch text-primary me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Git Repository</h6>
                  <% if @deployment.repository_url.present? %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= @deployment.deployment_method.humanize %>
                    </small>
                    <div class="text-muted small">
                      <%= truncate(@deployment.repository_url, length: 40) %>
                      <% if @deployment.repository_branch.present? %>
                        (branch: <%= @deployment.repository_branch %>)
                      <% end %>
                    </div>
                  <% else %>
                    <small class="text-warning">
                      <i class="fas fa-exclamation-triangle me-1"></i>
                      Not configured
                    </small>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Environment Variables -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-list-ul text-info me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Environment Variables</h6>
                  <% env_count = @deployment.environment_variables.count %>
                  <% if env_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(env_count, 'variable') %> configured
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No variables set
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <!-- Database Configuration -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-database text-success me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Database</h6>
                  <% if @deployment.database_configuration&.configured? %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= @deployment.database_configuration.display_name %>
                      <% if @deployment.database_configuration.redis_enabled? %>
                        + Redis
                      <% end %>
                    </small>
                  <% elsif @deployment.database_configuration&.persisted? %>
                    <small class="text-warning">
                      <i class="fas fa-exclamation-triangle me-1"></i>
                      <%= @deployment.database_configuration.display_name %> (pending)
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      Not configured
                    </small>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- SSH Keys -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-key text-warning me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">SSH Keys</h6>
                  <% ssh_count = @deployment.ssh_keys.count %>
                  <% if ssh_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(ssh_count, 'key') %> attached
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No keys attached
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <!-- Domains -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-globe text-info me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Domains</h6>
                  <% domain_count = @deployment.domains.count %>
                  <% if domain_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(domain_count, 'domain') %> configured
                    </small>
                    <% if @deployment.domains.any? %>
                      <div class="text-muted small">
                        <%= @deployment.domains.limit(2).pluck(:name).join(', ') %>
                        <% if domain_count > 2 %>
                          and <%= domain_count - 2 %> more...
                        <% end %>
                      </div>
                    <% end %>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No custom domains
                    </small>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Deployment Readiness -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-rocket text-<%= @deployment.can_deploy? ? 'success' : 'warning' %> me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Deployment Ready</h6>
                  <% if @deployment.can_deploy? %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      Ready to deploy
                    </small>
                  <% else %>
                    <small class="text-warning">
                      <i class="fas fa-exclamation-triangle me-1"></i>
                      Configuration needed
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <!-- Configuration Progress Bar -->
          <div class="row mt-3">
            <div class="col-12">
              <%
                config_items = [
                  @deployment.repository_url.present?,
                  @deployment.database_configuration&.configured?,
                  @deployment.ssh_keys.any?,
                  @deployment.domains.any?
                ]
                completed_items = config_items.count(true)
                total_items = config_items.length
                progress_percentage = (completed_items.to_f / total_items * 100).round
              %>

              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="text-muted mb-0">Configuration Progress</h6>
                <small class="text-muted"><%= completed_items %>/<%= total_items %> completed</small>
              </div>

              <div class="progress mb-2" style="height: 8px;">
                <div class="progress-bar bg-<%= progress_percentage == 100 ? 'success' : progress_percentage >= 50 ? 'info' : 'warning' %>"
                     role="progressbar"
                     style="width: <%= progress_percentage %>%"
                     aria-valuenow="<%= progress_percentage %>"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
              </div>

              <% if progress_percentage < 100 %>
                <small class="text-muted">
                  <i class="fas fa-info-circle me-1"></i>
                  Complete remaining configurations to optimize your deployment setup.
                </small>
              <% else %>
                <small class="text-success">
                  <i class="fas fa-check-circle me-1"></i>
                  All main configurations completed! Your deployment is fully configured.
                </small>
              <% end %>
            </div>
          </div>

          <hr class="my-4">

          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Created</h6>
              <p class="mb-0">
                <%= @deployment.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                <small class="text-muted d-block"><%= time_ago_in_words(@deployment.created_at) %> ago</small>
              </p>
            </div>
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Last Updated</h6>
              <p class="mb-0">
                <%= @deployment.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                <small class="text-muted d-block"><%= time_ago_in_words(@deployment.updated_at) %> ago</small>
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- Deployment URL -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-globe me-2"></i>Application URL
          </h6>
        </div>
        <div class="card-body">
          <% if @deployment.dokku_url.present? %>
            <div class="bg-dark text-white p-3 rounded position-relative">
              <pre class="text-white mb-0" style="font-size: 0.875rem;"><%= @deployment.dokku_url %></pre>
              <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2" 
                      onclick="copyToClipboard(this)" 
                      data-text="<%= @deployment.dokku_url %>">
                <i class="fas fa-copy"></i> Copy
              </button>
            </div>
            <div class="form-text mt-2 d-flex justify-content-between align-items-center">
              <span>
                <i class="fas fa-info-circle me-1"></i>
                This is your application's public URL
              </span>
              <%= link_to @deployment.dokku_url,
                  target: "_blank", rel: "noopener", 
                  class: "btn btn-sm btn-outline-primary" do %>
                <i class="fas fa-external-link-alt me-1"></i>Visit App
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-3">
              <i class="fas fa-globe fa-2x text-muted mb-3"></i>
              <h6 class="text-muted">URL Not Available</h6>
              <p class="text-muted small mb-0">
                The application URL will be available after deployment
              </p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Deployment Instructions -->
      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-terminal me-2"></i>Manual Deployment Instructions
          </h6>
        </div>
        <div class="card-body">
          <p class="text-muted mb-3">
            You can deploy your application to Dokku using Git. Make sure you have SSH access to the server.
          </p>
          
          <h6>1. Add Dokku remote to your Git repository:</h6>
          <div class="bg-dark text-white p-3 rounded mb-3 position-relative">
            <code class="text-white">git remote add dokku dokku@<%= @deployment.server.ip %>:<%= @deployment.dokku_app_name %></code>
            <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2" 
                    onclick="copyToClipboard(this)" 
                    data-text="git remote add dokku dokku@<%= @deployment.server.ip %>:<%= @deployment.dokku_app_name %>">
              <i class="fas fa-copy"></i>
            </button>
          </div>
          
          <h6>2. Deploy your application:</h6>
          <div class="bg-dark text-white p-3 rounded mb-3 position-relative">
            <code class="text-white">git push dokku main</code>
            <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2" 
                    onclick="copyToClipboard(this)" 
                    data-text="git push dokku main">
              <i class="fas fa-copy"></i>
            </button>
          </div>
          
          <% unless @deployment.can_deploy? %>
            <div class="alert alert-warning">
              <i class="fas fa-exclamation-triangle me-2"></i>
              <strong>Deployment Requirements:</strong>
              <% unless @deployment.server.dokku_installed? %>
                Server must have Dokku installed.
              <% end %>
              <% unless @deployment.server.connection_status == 'connected' %>
                Server connection must be verified.
              <% end %>
            </div>
          <% end %>
          
          <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            <strong>First Deployment:</strong> Dokku will automatically detect your application type and create the necessary containers.
          </div>
        </div>
      </div>
    </div>

    <!-- Actions Sidebar -->
    <div class="col-md-4">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cogs me-2"></i>Quick Actions
          </h6>
        </div>
        <div class="card-body">
          <div class="d-grid gap-2">
            <div id="deploy-action-wrapper"
                 data-deploy-url="<%= deploy_deployment_path(@deployment) %>"
                 data-logs-url="<%= logs_deployment_path(@deployment) %>"
                 data-deployment-uuid="<%= @deployment.uuid %>"
                 data-deployment-name="<%= j @deployment.name %>"
                 data-can-deploy="<%= @deployment.can_deploy? %>"
                 data-deployment-configured="<%= @deployment.deployment_configured? %>">
              <% if @deployment.deployment_status == 'deploying' %>
                <%= link_to logs_deployment_path(@deployment), class: "btn btn-warning w-100" do %>
                  <i class="fas fa-spinner fa-spin me-2"></i>View Deployment
                <% end %>
              <% elsif @deployment.can_deploy? && @deployment.deployment_configured? %>
                <button id="deploy-now-btn" class="btn btn-success w-100"
                        data-deploy-url="<%= deploy_deployment_path(@deployment) %>"
                        data-deployment-uuid="<%= @deployment.uuid %>"
                        data-deployment-name="<%= j @deployment.name %>">
                  <i class="fas fa-rocket me-2"></i>Deploy Now
                </button>
              <% end %>
            </div>
            
            <% if @deployment.dokku_url.present? %>
              <%= link_to @deployment.dokku_url, target: "_blank", rel: "noopener", class: "btn btn-outline-success" do %>
                <i class="fas fa-external-link-alt me-2"></i>Visit Application
              <% end %>
            <% end %>
            
            <%= link_to edit_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-edit me-2"></i>Edit Application
            <% end %>

            <%= link_to deployment_path(@deployment),
                        class: "btn btn-outline-danger",
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "Are you sure you want to delete '#{@deployment.name}'? This action cannot be undone."
                        } do %>
              <i class="fas fa-trash me-2"></i>Delete Application
            <% end %>
          </div>
        </div>
      </div>

      <!-- Configuration Menu -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cog me-2"></i>Management & Configuration
          </h6>
        </div>
        <div class="card-body">
          <div id="deployment-mgmt-alert">
            <% if @deployment.deployment_status == 'deploying' %>
              <div class="alert alert-warning py-2">
                <i class="fas fa-spinner fa-spin me-2"></i>
                <strong>Deployment in progress!</strong>
                <%= link_to "View logs", logs_deployment_path(@deployment), class: "alert-link" %> to monitor progress.
              </div>
            <% elsif @deployment.can_deploy? && @deployment.deployment_configured? %>
              <div class="alert alert-success py-2">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Ready to deploy!</strong> Configuration complete and server connected.
              </div>
            <% elsif !@deployment.deployment_configured? %>
              <div class="alert alert-info py-2">
                <i class="fas fa-cogs me-2"></i>
                <strong>Configuration needed:</strong>
                <%= link_to "Configure Git repository", git_configuration_deployment_path(@deployment), class: "alert-link" %> to enable deployment.
              </div>
            <% elsif !@deployment.can_deploy? %>
              <div class="alert alert-warning py-2">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Server not ready:</strong>
                <% unless @deployment.server.dokku_installed? %>
                  Install Dokku on the server first.
                <% end %>
                <% unless @deployment.server.connection_status == 'connected' %>
                  Verify server connection.
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="d-grid gap-2">
            <%= link_to git_configuration_deployment_path(@deployment), class: "btn btn-outline-success",
                        data: { turbo: false } do %>
              <i class="fab fa-git-alt me-2"></i>Git Configuration
            <% end %>
            
            <%= link_to configure_domain_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-globe me-2"></i>Configure Domain
            <% end %>
            
            <%= link_to attach_ssh_keys_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-key me-2"></i>Attach SSH Keys
            <% end %>
            
            <%= link_to manage_environment_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-cogs me-2"></i>Environment Variables
            <% end %>
            
            <%= link_to configure_databases_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-database me-2"></i>Configure Databases
            <% end %>

            <%= link_to port_mappings_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-network-wired me-2"></i>Port Mappings
            <% end %>

            <%= link_to execute_commands_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-terminal me-2"></i>Execute Commands
            <% end %>
            
            <%= link_to server_logs_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-file-alt me-2"></i>View Server Logs
            <% end %>

            <%= link_to logs_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-list me-2"></i>Deployment Logs
            <% end %>

            <%= link_to scans_deployment_path(@deployment), class: "btn btn-outline-danger", data: { turbo: false } do %>
              <i class="fas fa-shield-alt me-2"></i>Vulnerability Scans
            <% end %>

            <%= link_to @deployment.server, class: "btn btn-outline-warning" do %>
              <i class="fas fa-server me-2"></i>Manage Server
            <% end %>
          </div>
        </div>
      </div>

      <!-- Server Information -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-server me-2"></i>Server Details
          </h6>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <h6 class="text-muted">Server Name</h6>
            <p class="mb-0"><%= @deployment.server.name %></p>
          </div>
          
          <div class="mb-3">
            <h6 class="text-muted">IP Address</h6>
            <code class="text-info"><%= @deployment.server.ip %></code>
          </div>
          
          <div class="mb-3">
            <h6 class="text-muted">Dokku Version</h6>
            <% if @deployment.server.dokku_installed? %>
              <span class="badge bg-success fs-6"><%= @deployment.server.formatted_dokku_version %></span>
            <% else %>
              <span class="text-muted">Not installed</span>
            <% end %>
          </div>
          
          <div class="mb-3">
            <h6 class="text-muted">Connection Status</h6>
            <span class="badge <%= @deployment.server.connection_status_badge_class %> fs-6">
              <i class="<%= @deployment.server.connection_status_icon %> me-1"></i>
              <%= @deployment.server.connection_status.titleize %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// --- DOM helpers ---
function _icon(cls) {
  const i = document.createElement('i');
  i.className = cls;
  return i;
}

function _alert(type, iconCls, boldText, rest) {
  const div   = document.createElement('div');
  div.className = 'alert alert-' + type + ' py-2';
  div.appendChild(_icon('fas fa-' + iconCls + ' me-2'));
  const strong = document.createElement('strong');
  strong.textContent = boldText;
  div.appendChild(strong);
  if (rest) div.appendChild(document.createTextNode(rest));
  return div;
}

function _alertWithLink(type, iconCls, boldText, linkHref, linkText, linkSuffix) {
  const div = _alert(type, iconCls, boldText, null);
  const a   = document.createElement('a');
  a.href      = linkHref;
  a.className = 'alert-link';
  a.textContent = linkText;
  div.appendChild(document.createTextNode(' '));
  div.appendChild(a);
  if (linkSuffix) div.appendChild(document.createTextNode(linkSuffix));
  return div;
}

function _deployBtn(deployUrl, uuid, name) {
  const btn = document.createElement('button');
  btn.id = 'deploy-now-btn';
  btn.className = 'btn btn-success w-100';
  btn.dataset.deployUrl       = deployUrl;
  btn.dataset.deploymentUuid  = uuid;
  btn.dataset.deploymentName  = name;
  btn.appendChild(_icon('fas fa-rocket me-2'));
  btn.appendChild(document.createTextNode('Deploy Now'));
  return btn;
}

function _viewDeployBtn(logsUrl) {
  const a = document.createElement('a');
  a.href      = logsUrl;
  a.className = 'btn btn-warning w-100';
  a.appendChild(_icon('fas fa-spinner fa-spin me-2'));
  a.appendChild(document.createTextNode('View Deployment'));
  return a;
}

// --- Status updates ---

function markDeploying(logsUrl) {
  const badge      = document.getElementById('status-badge');
  const icon       = document.getElementById('status-icon');
  const statusText = document.getElementById('status-text');
  if (badge)      badge.className      = 'badge bg-warning text-dark fs-6';
  if (icon)       icon.className       = 'fas fa-spinner fa-spin me-1';
  if (statusText) statusText.textContent = 'Deploying...';

  const wrapper = document.getElementById('deploy-action-wrapper');
  if (wrapper) wrapper.replaceChildren(_viewDeployBtn(logsUrl));

  const mgmtAlert = document.getElementById('deployment-mgmt-alert');
  if (mgmtAlert) mgmtAlert.replaceChildren(
    _alertWithLink('warning', 'spinner fa-spin', 'Deployment in progress!', logsUrl, 'View logs', ' to monitor progress.')
  );
}

function updateDeploymentStatus(success) {
  const badge      = document.getElementById('status-badge');
  const icon       = document.getElementById('status-icon');
  const statusText = document.getElementById('status-text');
  if (badge && icon && statusText) {
    if (success) {
      badge.className       = 'badge bg-success fs-6';
      icon.className        = 'fas fa-check-circle me-1';
      statusText.textContent = 'Deployed';
    } else {
      badge.className       = 'badge bg-danger fs-6';
      icon.className        = 'fas fa-times-circle me-1';
      statusText.textContent = 'Failed';
    }
  }

  const sup  = document.getElementById('last-deployed-sup');
  const span = document.getElementById('last-deployed-text');
  if (sup)  sup.style.display   = '';
  if (span) span.textContent    = 'just now';

  const wrapper = document.getElementById('deploy-action-wrapper');
  if (wrapper) {
    const canDeploy  = wrapper.dataset.canDeploy === 'true';
    const configured = wrapper.dataset.deploymentConfigured === 'true';
    wrapper.replaceChildren();
    if (canDeploy && configured) {
      const btn = _deployBtn(
        wrapper.dataset.deployUrl,
        wrapper.dataset.deploymentUuid,
        wrapper.dataset.deploymentName
      );
      wrapper.appendChild(btn);
      attachDeployBtnListener();
    }
  }

  const mgmtAlert = document.getElementById('deployment-mgmt-alert');
  if (mgmtAlert) {
    mgmtAlert.replaceChildren(
      success
        ? _alert('success', 'check-circle',        'Deployed successfully!', ' Ready to deploy again when needed.')
        : _alert('warning', 'exclamation-triangle', 'Deployment failed.',     ' Check the deployment logs for details.')
    );
  }
}

// --- Deploy button ---

function attachDeployBtnListener() {
  const deployBtn = document.getElementById('deploy-now-btn');
  if (!deployBtn || deployBtn._bound) return;
  deployBtn._bound = true;

  deployBtn.addEventListener('click', async function() {
    const url     = deployBtn.dataset.deployUrl;
    const uuid    = deployBtn.dataset.deploymentUuid;
    const name    = deployBtn.dataset.deploymentName;
    const logsUrl = document.getElementById('deploy-action-wrapper')?.dataset.logsUrl || '#';

    const ok = await window.appConfirm({
      title: 'Deploy Now',
      bodyHtml: 'Start deployment for <strong>' + name + '</strong>? This will clone the repository and deploy to Dokku.',
      confirmLabel: 'Deploy',
    });
    if (!ok) return;

    deployBtn.disabled = true;
    deployBtn.replaceChildren(
      _icon('fas fa-spinner fa-spin me-2'),
      document.createTextNode('Starting deployment...')
    );

    fetch(url, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
        'Accept': 'application/json',
        'Content-Type': 'application/json',
      }
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        markDeploying(logsUrl);
        window.dispatchEvent(new CustomEvent('live-console:start', {
          detail: {
            id: 'deploy-' + uuid,
            label: 'Deploying ' + name,
            channelName: 'DeploymentLogsChannel',
            channelParams: { deployment_uuid: uuid },
            onComplete: function({ success }) {
              updateDeploymentStatus(success);
            }
          }
        }));
      } else {
        deployBtn.disabled = false;
        deployBtn.replaceChildren(
          _icon('fas fa-rocket me-2'),
          document.createTextNode('Deploy Now')
        );
      }
    })
    .catch(() => {
      deployBtn.disabled = false;
      deployBtn.replaceChildren(
        _icon('fas fa-rocket me-2'),
        document.createTextNode('Deploy Now')
      );
    });
  });
}

document.addEventListener('DOMContentLoaded', function() {
  attachDeployBtnListener();
});

<% if @deployment.deployment_status == 'deploying' %>
// Page loaded while deployment is already running — subscribe to watch for completion
(function() {
  const uuid = '<%= @deployment.uuid %>';
  const name = '<%= j @deployment.name %>';

  document.addEventListener('turbo:load', function() {
    window.dispatchEvent(new CustomEvent('live-console:start', {
      detail: {
        id: 'deploy-' + uuid,
        label: 'Deploying ' + name,
        channelName: 'DeploymentLogsChannel',
        channelParams: { deployment_uuid: uuid },
        onComplete: function({ success }) {
          updateDeploymentStatus(success);
        }
      }
    }));
  }, { once: true });
})();
<% end %>

function copyToClipboard(button) {
  const text = button.getAttribute('data-text');
  navigator.clipboard.writeText(text).then(function() {
    const originalText = button.textContent;
    button.replaceChildren(
      _icon('fas fa-check me-2'),
      document.createTextNode('Copied!')
    );
    setTimeout(() => {
      button.replaceChildren(
        _icon('fas fa-copy'),
        document.createTextNode(' Copy')
      );
    }, 2000);
  }).catch(function(err) {
    console.error('Failed to copy text: ', err);
    showToast('error', 'Failed to copy to clipboard. Please copy it manually.', 'Copy Failed');
  });
}
</script>

