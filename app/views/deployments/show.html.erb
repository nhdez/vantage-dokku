<% content_for :title, @deployment.name %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-rocket me-2 text-primary"></i>
            <%= @deployment.name %>
          </h1>
          <p class="text-muted mb-0">
            <% if @deployment.kamal? %>
              <i class="fas fa-ship text-info me-1"></i>Kamal deployment
              <% if @deployment.kamal_configuration&.service_name.present? %>
                &mdash; service: <code class="text-info"><%= @deployment.kamal_configuration.service_name %></code>
              <% end %>
            <% else %>
              Dokku application: <code class="text-info"><%= @deployment.dokku_app_name %></code>
            <% end %>
          </p>
        </div>
        <div>
          <%= link_to edit_deployment_path(@deployment), class: "btn btn-primary me-2" do %>
            <i class="fas fa-edit me-2"></i>Edit App
          <% end %>
          <%= link_to deployments_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to Apps
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Application Information -->
    <div class="col-md-8">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>Application Information
          </h6>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Application Name</h6>
              <p class="h5 mb-0"><%= @deployment.name %></p>
            </div>
            <div class="col-md-6 mb-3">
              <% if @deployment.kamal? %>
                <h6 class="text-muted">Docker Image</h6>
                <p class="h5 mb-0">
                  <code class="text-info fs-6"><%= @deployment.kamal_configuration&.image.presence || "Not set" %></code>
                </p>
              <% else %>
                <h6 class="text-muted">Dokku App Name</h6>
                <p class="h5 mb-0">
                  <code class="text-info fs-6"><%= @deployment.dokku_app_name %></code>
                </p>
              <% end %>
            </div>
          </div>
          
          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Status</h6>
              <p class="h5 mb-0">
                <span class="badge <%= @deployment.status_badge_class %> fs-6">
                  <i class="<%= @deployment.status_icon %> me-1"></i>
                  <%= @deployment.status_text %>
                </span>
              </p>
              <% if @deployment.last_deployment_at.present? %>
                <sup><strong>Last deployed:</strong> <%= time_ago_in_words(@deployment.last_deployment_at) %> ago</sup>
              <% end %>
            </div>
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Target Server</h6>
              <p class="h5 mb-0">
                <div class="d-flex align-items-center">
                  <i class="fas fa-server text-secondary me-2"></i>
                  <%= link_to @deployment.server_name, @deployment.server, class: "text-decoration-none" %>
                  <% if @deployment.server.dokku_installed? %>
                    <span class="badge bg-success ms-2">Dokku Installed</span>
                  <% else %>
                    <span class="badge bg-warning text-dark ms-2">No Dokku</span>
                  <% end %>
                </div>
              </p>
            </div>
          </div>
          
          <% if @deployment.description.present? %>
            <div class="row">
              <div class="col-md-12 mb-3">
                <h6 class="text-muted">Description</h6>
                <p class="mb-0"><%= @deployment.description %></p>
              </div>
            </div>
          <% end %>

          <!-- Latest Vulnerability Scan -->
          <% if @latest_vulnerability_scan.present? %>
            <hr class="my-3">
            <div class="row">
              <div class="col-md-12">
                <h6 class="text-muted">
                  <i class="fas fa-shield-alt me-1"></i>Latest Vulnerability Scan
                </h6>
                <div class="d-flex align-items-center justify-content-between">
                  <div>
                    <% if @latest_vulnerability_scan.vulnerabilities_found > 0 %>
                      <span class="badge bg-<%= @latest_vulnerability_scan.severity_badge_class %> me-2">
                        <%= @latest_vulnerability_scan.vulnerabilities_found %>
                        <%= 'vulnerability'.pluralize(@latest_vulnerability_scan.vulnerabilities_found) %> found
                      </span>
                      <small class="text-muted"><%= @latest_vulnerability_scan.severity_summary %></small>
                    <% else %>
                      <span class="badge bg-success me-2">
                        <i class="fas fa-check-circle me-1"></i>No vulnerabilities
                      </span>
                    <% end %>
                    <br>
                    <small class="text-muted">
                      Scanned <%= time_ago_in_words(@latest_vulnerability_scan.created_at) %> ago
                    </small>
                  </div>
                  <div>
                    <%= link_to scans_deployment_path(@deployment), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="fas fa-list me-1"></i>View All Scans
                    <% end %>
                    <% if @latest_vulnerability_scan.vulnerabilities_found > 0 %>
                      <%= link_to deployment_vulnerability_scan_path(@deployment, @latest_vulnerability_scan), class: "btn btn-sm btn-primary ms-2" do %>
                        <i class="fas fa-eye me-1"></i>View Report
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Configuration Overview -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cog me-2"></i>Configuration Information
          </h6>
        </div>
        <div class="card-body">
          <div class="row">
            <!-- Git Repository / Kamal Config -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-<%= @deployment.kamal? ? 'ship' : 'code-branch' %> text-primary me-2"></i>
                <div class="flex-grow-1">
                  <% if @deployment.kamal? %>
                    <h6 class="mb-0">Kamal Configuration</h6>
                    <% kc = @deployment.kamal_configuration %>
                    <% if kc&.configured? %>
                      <small class="text-success"><i class="fas fa-check-circle me-1"></i>Configured</small>
                      <div class="text-muted small"><%= kc.service_name %> — <%= kc.web_servers.count %> web server(s)</div>
                    <% else %>
                      <small class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>
                        <%= link_to "Configure Kamal", kamal_configuration_deployment_path(@deployment), class: "text-warning" %>
                      </small>
                    <% end %>
                  <% else %>
                    <h6 class="mb-0">Git Repository</h6>
                    <% if @deployment.repository_url.present? %>
                      <small class="text-success"><i class="fas fa-check-circle me-1"></i><%= @deployment.deployment_method.humanize %></small>
                      <div class="text-muted small">
                        <%= truncate(@deployment.repository_url, length: 40) %>
                        <% if @deployment.repository_branch.present? %>
                          (branch: <%= @deployment.repository_branch %>)
                        <% end %>
                      </div>
                    <% else %>
                      <small class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>Not configured</small>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Environment Variables -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-list-ul text-info me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Environment Variables</h6>
                  <% env_count = @deployment.environment_variables.count %>
                  <% if env_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(env_count, 'variable') %> configured
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No variables set
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <!-- Database Configuration -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-database text-success me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Database</h6>
                  <% if @deployment.database_configuration&.configured? %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= @deployment.database_configuration.display_name %>
                      <% if @deployment.database_configuration.redis_enabled? %>
                        + Redis
                      <% end %>
                    </small>
                  <% elsif @deployment.database_configuration&.persisted? %>
                    <small class="text-warning">
                      <i class="fas fa-exclamation-triangle me-1"></i>
                      <%= @deployment.database_configuration.display_name %> (pending)
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      Not configured
                    </small>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- SSH Keys -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-key text-warning me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">SSH Keys</h6>
                  <% ssh_count = @deployment.ssh_keys.count %>
                  <% if ssh_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(ssh_count, 'key') %> attached
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No keys attached
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <!-- Domains -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-globe text-info me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Domains</h6>
                  <% domain_count = @deployment.domains.count %>
                  <% if domain_count > 0 %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      <%= pluralize(domain_count, 'domain') %> configured
                    </small>
                    <% if @deployment.domains.any? %>
                      <div class="text-muted small">
                        <%= @deployment.domains.limit(2).pluck(:name).join(', ') %>
                        <% if domain_count > 2 %>
                          and <%= domain_count - 2 %> more...
                        <% end %>
                      </div>
                    <% end %>
                  <% else %>
                    <small class="text-muted">
                      <i class="fas fa-circle me-1"></i>
                      No custom domains
                    </small>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Deployment Readiness -->
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-center">
                <i class="fas fa-rocket text-<%= @deployment.can_deploy? ? 'success' : 'warning' %> me-2"></i>
                <div class="flex-grow-1">
                  <h6 class="mb-0">Deployment Ready</h6>
                  <% if @deployment.can_deploy? %>
                    <small class="text-success">
                      <i class="fas fa-check-circle me-1"></i>
                      Ready to deploy
                    </small>
                  <% else %>
                    <small class="text-warning">
                      <i class="fas fa-exclamation-triangle me-1"></i>
                      Configuration needed
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <!-- Configuration Progress Bar -->
          <div class="row mt-3">
            <div class="col-12">
              <%
                config_items = [
                  @deployment.repository_url.present?,
                  @deployment.database_configuration&.configured?,
                  @deployment.ssh_keys.any?,
                  @deployment.domains.any?
                ]
                completed_items = config_items.count(true)
                total_items = config_items.length
                progress_percentage = (completed_items.to_f / total_items * 100).round
              %>

              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="text-muted mb-0">Configuration Progress</h6>
                <small class="text-muted"><%= completed_items %>/<%= total_items %> completed</small>
              </div>

              <div class="progress mb-2" style="height: 8px;">
                <div class="progress-bar bg-<%= progress_percentage == 100 ? 'success' : progress_percentage >= 50 ? 'info' : 'warning' %>"
                     role="progressbar"
                     style="width: <%= progress_percentage %>%"
                     aria-valuenow="<%= progress_percentage %>"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
              </div>

              <% if progress_percentage < 100 %>
                <small class="text-muted">
                  <i class="fas fa-info-circle me-1"></i>
                  Complete remaining configurations to optimize your deployment setup.
                </small>
              <% else %>
                <small class="text-success">
                  <i class="fas fa-check-circle me-1"></i>
                  All main configurations completed! Your deployment is fully configured.
                </small>
              <% end %>
            </div>
          </div>

          <hr class="my-4">

          <div class="row">
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Created</h6>
              <p class="mb-0">
                <%= @deployment.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                <small class="text-muted d-block"><%= time_ago_in_words(@deployment.created_at) %> ago</small>
              </p>
            </div>
            <div class="col-md-6 mb-3">
              <h6 class="text-muted">Last Updated</h6>
              <p class="mb-0">
                <%= @deployment.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                <small class="text-muted d-block"><%= time_ago_in_words(@deployment.updated_at) %> ago</small>
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- Deployment URL -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-globe me-2"></i>Application URL
          </h6>
        </div>
        <div class="card-body">
          <% if @deployment.dokku_url.present? %>
            <div class="bg-dark text-white p-3 rounded position-relative">
              <pre class="text-white mb-0" style="font-size: 0.875rem;"><%= @deployment.dokku_url %></pre>
              <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2" 
                      onclick="copyToClipboard(this)" 
                      data-text="<%= @deployment.dokku_url %>">
                <i class="fas fa-copy"></i> Copy
              </button>
            </div>
            <div class="form-text mt-2 d-flex justify-content-between align-items-center">
              <span>
                <i class="fas fa-info-circle me-1"></i>
                This is your application's public URL
              </span>
              <%= link_to @deployment.dokku_url,
                  target: "_blank", rel: "noopener", 
                  class: "btn btn-sm btn-outline-primary" do %>
                <i class="fas fa-external-link-alt me-1"></i>Visit App
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-3">
              <i class="fas fa-globe fa-2x text-muted mb-3"></i>
              <h6 class="text-muted">URL Not Available</h6>
              <p class="text-muted small mb-0">
                The application URL will be available after deployment
              </p>
            </div>
          <% end %>
        </div>
      </div>

      <% if @deployment.kamal? %>
        <!-- Kamal deployment info -->
        <div class="card shadow">
          <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-ship me-2"></i>Kamal Deployment
            </h6>
          </div>
          <div class="card-body">
            <% kc = @deployment.kamal_configuration %>
            <% if kc&.proxy_host.present? %>
              <div class="mb-3">
                <h6 class="text-muted">Application URL</h6>
                <% url = @deployment.app_url %>
                <a href="<%= url %>" target="_blank" rel="noopener" class="text-info"><%= url %></a>
              </div>
            <% end %>
            <div class="row small">
              <div class="col-md-4">
                <strong>Service:</strong> <%= kc&.service_name.presence || "—" %><br>
                <strong>Image:</strong> <code><%= kc&.image.presence || "—" %></code>
              </div>
              <div class="col-md-4">
                <strong>Builder:</strong> <%= kc&.builder_arch %><br>
                <strong>Proxy SSL:</strong> <%= kc&.proxy_ssl ? "Yes" : "No" %>
              </div>
              <div class="col-md-4">
                <strong>Web servers:</strong> <%= kc&.web_servers&.count || 0 %><br>
                <strong>Accessories:</strong> <%= kc&.kamal_accessories&.count || 0 %>
              </div>
            </div>
            <div class="mt-3 d-flex gap-2">
              <%= link_to kamal_configuration_deployment_path(@deployment), class: "btn btn-outline-info btn-sm" do %>
                <i class="fas fa-cog me-1"></i>Configure
              <% end %>
              <% if kc && KamalConfigGenerator.new(kc).valid_for_generation? %>
                <%= button_to "Run Setup", kamal_setup_deployment_path(@deployment),
                      method: :post, class: "btn btn-outline-warning btn-sm",
                      data: { confirm: "Run kamal setup on all assigned servers?" } %>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Dokku deployment instructions -->
        <div class="card shadow">
          <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
              <i class="fas fa-terminal me-2"></i>Manual Deployment Instructions
            </h6>
          </div>
          <div class="card-body">
            <p class="text-muted mb-3">Deploy your application to Dokku using Git.</p>
            <h6>1. Add Dokku remote:</h6>
            <div class="bg-dark text-white p-3 rounded mb-3 position-relative">
              <code class="text-white">git remote add dokku dokku@<%= @deployment.server.ip %>:<%= @deployment.dokku_app_name %></code>
              <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2"
                      onclick="copyToClipboard(this)"
                      data-text="git remote add dokku dokku@<%= @deployment.server.ip %>:<%= @deployment.dokku_app_name %>">
                <i class="fas fa-copy"></i>
              </button>
            </div>
            <h6>2. Deploy:</h6>
            <div class="bg-dark text-white p-3 rounded mb-3 position-relative">
              <code class="text-white">git push dokku main</code>
              <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 mt-2 me-2"
                      onclick="copyToClipboard(this)" data-text="git push dokku main">
                <i class="fas fa-copy"></i>
              </button>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Actions Sidebar -->
    <div class="col-md-4">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cogs me-2"></i>Quick Actions
          </h6>
        </div>
        <div class="card-body">
          <div class="d-grid gap-2">
            <% if @deployment.deployment_status == 'deploying' %>
              <%= link_to logs_deployment_path(@deployment), class: "btn btn-warning w-100" do %>
                <i class="fas fa-spinner fa-spin me-2"></i>View Deployment
              <% end %>
            <% elsif @deployment.can_deploy? %>
              <%= form_with url: deploy_deployment_path(@deployment), method: :post, local: true do |f| %>
                <%= submit_tag "Deploy Now", class: "btn btn-success w-100",
                    data: { confirm: "Start deployment?", turbo: false } %>
              <% end %>
            <% end %>

            <% if @deployment.kamal? && @deployment.deployment_status == 'deployed' %>
              <%= button_to "Restart", kamal_restart_deployment_path(@deployment),
                    method: :post, class: "btn btn-outline-warning",
                    data: { confirm: "Restart the app containers?" } %>
              <%= button_to "Stop", kamal_stop_deployment_path(@deployment),
                    method: :post, class: "btn btn-outline-danger",
                    data: { confirm: "Stop the app?" } %>
            <% end %>

            <% app_url = @deployment.kamal? ? @deployment.app_url : @deployment.dokku_url %>
            <% if app_url.present? %>
              <%= link_to app_url, target: "_blank", rel: "noopener", class: "btn btn-outline-success" do %>
                <i class="fas fa-external-link-alt me-2"></i>Visit Application
              <% end %>
            <% end %>

            <%= link_to edit_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-edit me-2"></i>Edit Application
            <% end %>

            <%= link_to deployment_path(@deployment),
                        class: "btn btn-outline-danger",
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "Are you sure you want to delete '#{@deployment.name}'? This action cannot be undone."
                        } do %>
              <i class="fas fa-trash me-2"></i>Delete Application
            <% end %>
          </div>
        </div>
      </div>

      <!-- Configuration Menu -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cog me-2"></i>Management & Configuration
          </h6>
        </div>
        <div class="card-body">
          <% if @deployment.deployment_status == 'deploying' %>
            <div class="alert alert-warning py-2">
              <i class="fas fa-spinner fa-spin me-2"></i>
              <strong>Deployment in progress!</strong>
              <%= link_to "View logs", logs_deployment_path(@deployment), class: "alert-link" %> to monitor progress.
            </div>
          <% elsif @deployment.can_deploy? && @deployment.deployment_configured? %>
            <div class="alert alert-success py-2">
              <i class="fas fa-check-circle me-2"></i>
              <strong>Ready to deploy!</strong> Configuration complete and server connected.
            </div>
          <% elsif !@deployment.deployment_configured? && !@deployment.kamal? %>
            <div class="alert alert-info py-2">
              <i class="fas fa-cogs me-2"></i>
              <strong>Configuration needed:</strong>
              <%= link_to "Configure Git repository", git_configuration_deployment_path(@deployment), class: "alert-link" %> to enable deployment.
            </div>
          <% elsif @deployment.kamal? && !@deployment.can_deploy? %>
            <div class="alert alert-warning py-2">
              <i class="fas fa-exclamation-triangle me-2"></i>
              <strong>Kamal not ready:</strong>
              <%= link_to "Complete configuration", kamal_configuration_deployment_path(@deployment), class: "alert-link" %>
            </div>
          <% elsif !@deployment.can_deploy? %>
            <div class="alert alert-warning py-2">
              <i class="fas fa-exclamation-triangle me-2"></i>
              <strong>Server not ready:</strong>
              <% unless @deployment.server.dokku_installed? %>Install Dokku on the server first.<% end %>
              <% unless @deployment.server.connection_status == 'connected' %>Verify server connection.<% end %>
            </div>
          <% end %>

          <div class="d-grid gap-2">
            <% if @deployment.kamal? %>
              <%= link_to kamal_configuration_deployment_path(@deployment), class: "btn btn-outline-info" do %>
                <i class="fas fa-ship me-2"></i>Kamal Configuration
              <% end %>
              <%= link_to kamal_registry_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
                <i class="fas fa-key me-2"></i>Registry Credentials
              <% end %>
              <%= link_to kamal_accessories_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
                <i class="fas fa-boxes me-2"></i>Accessories
              <% end %>
              <%= link_to kamal_config_preview_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
                <i class="fas fa-file-code me-2"></i>Preview deploy.yml
              <% end %>
            <% else %>
              <%= link_to git_configuration_deployment_path(@deployment), class: "btn btn-outline-success",
                          data: { turbo: false } do %>
                <i class="fab fa-git-alt me-2"></i>Git Configuration
              <% end %>
              <%= link_to configure_domain_deployment_path(@deployment), class: "btn btn-outline-primary",
                          data: { turbo: false } do %>
                <i class="fas fa-globe me-2"></i>Configure Domain
              <% end %>
              <%= link_to attach_ssh_keys_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
                <i class="fas fa-key me-2"></i>Attach SSH Keys
              <% end %>
              <%= link_to configure_databases_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
                <i class="fas fa-database me-2"></i>Configure Databases
              <% end %>
              <%= link_to port_mappings_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
                <i class="fas fa-network-wired me-2"></i>Port Mappings
              <% end %>
            <% end %>

            <%= link_to manage_environment_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-cogs me-2"></i>Environment Variables
            <% end %>
            <%= link_to execute_commands_deployment_path(@deployment), class: "btn btn-outline-primary",
                        data: { turbo: false } do %>
              <i class="fas fa-terminal me-2"></i>Execute Commands
            <% end %>
            <%= link_to logs_deployment_path(@deployment), class: "btn btn-outline-primary" do %>
              <i class="fas fa-list me-2"></i>Deployment Logs
            <% end %>
            <%= link_to scans_deployment_path(@deployment), class: "btn btn-outline-danger", data: { turbo: false } do %>
              <i class="fas fa-shield-alt me-2"></i>Vulnerability Scans
            <% end %>
            <%= link_to @deployment.server, class: "btn btn-outline-warning" do %>
              <i class="fas fa-server me-2"></i>Manage Server
            <% end %>
          </div>
        </div>
      </div>

      <!-- Server Information -->
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-server me-2"></i>Server Details
          </h6>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <h6 class="text-muted">Server Name</h6>
            <p class="mb-0"><%= @deployment.server.name %></p>
          </div>
          
          <div class="mb-3">
            <h6 class="text-muted">IP Address</h6>
            <code class="text-info"><%= @deployment.server.ip %></code>
          </div>
          
          <% if @deployment.kamal? %>
            <div class="mb-3">
              <h6 class="text-muted">Docker</h6>
              <% if @deployment.server.docker_installed? %>
                <span class="badge bg-success fs-6"><%= @deployment.server.formatted_docker_version %></span>
              <% else %>
                <span class="text-muted">Not detected</span>
                <%= button_to "Check", check_kamal_prerequisites_server_path(@deployment.server),
                      method: :post, class: "btn btn-link btn-sm p-0 ms-2" %>
              <% end %>
            </div>
          <% else %>
            <div class="mb-3">
              <h6 class="text-muted">Dokku Version</h6>
              <% if @deployment.server.dokku_installed? %>
                <span class="badge bg-success fs-6"><%= @deployment.server.formatted_dokku_version %></span>
              <% else %>
                <span class="text-muted">Not installed</span>
              <% end %>
            </div>
          <% end %>
          
          <div class="mb-3">
            <h6 class="text-muted">Connection Status</h6>
            <span class="badge <%= @deployment.server.connection_status_badge_class %> fs-6">
              <i class="<%= @deployment.server.connection_status_icon %> me-1"></i>
              <%= @deployment.server.connection_status.titleize %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function copyToClipboard(button) {
  const text = button.getAttribute('data-text');
  navigator.clipboard.writeText(text).then(function() {
    const icon = button.querySelector('i');
    const originalClasses = icon.className;
    icon.className = 'fas fa-check';
    
    // Show success feedback
    const originalText = button.innerHTML;
    button.innerHTML = '<i class="fas fa-check me-2"></i>Copied!';
    
    setTimeout(() => {
      button.innerHTML = originalText;
    }, 2000);
  }).catch(function(err) {
    console.error('Failed to copy text: ', err);
    alert('Failed to copy to clipboard');
  });
}
</script>

