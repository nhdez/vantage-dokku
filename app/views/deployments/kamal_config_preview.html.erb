<% content_for :title, "deploy.yml Preview — #{@deployment.name}" %>

<div class="container-fluid">
  <div class="row mb-4">
    <div class="col">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-gray-800">
            <i class="fas fa-file-code me-2 text-info"></i>deploy.yml Preview
          </h1>
          <p class="text-muted mb-0"><%= @deployment.name %></p>
        </div>
        <div class="d-flex gap-2">
          <%= link_to download_kamal_config_deployment_path(@deployment), class: "btn btn-outline-info btn-sm" do %>
            <i class="fas fa-download me-1"></i>Download deploy.yml
          <% end %>
          <%= link_to kamal_configuration_deployment_path(@deployment), class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-2"></i>Back
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <% if @generator.missing_fields.any? %>
    <div class="alert alert-warning">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <strong>Configuration incomplete — preview may be partial:</strong>
      <%= @generator.missing_fields.join("; ") %>
    </div>
  <% end %>

  <div class="row">
    <div class="col-lg-7">
      <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-file-alt me-2"></i>config/deploy.yml
          </h6>
          <button class="btn btn-sm btn-outline-secondary" onclick="copyCode('deploy-yml-code')">
            <i class="fas fa-copy me-1"></i>Copy
          </button>
        </div>
        <div class="card-body p-0">
          <pre id="deploy-yml-code" class="mb-0 p-3" style="background:#1e1e1e;color:#d4d4d4;font-size:0.8rem;max-height:600px;overflow-y:auto;border-radius:0 0 0.35rem 0.35rem;"><%= html_escape(@deploy_yml) %></pre>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card shadow mb-4">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-warning">
            <i class="fas fa-lock me-2"></i>.kamal/secrets (values redacted)
          </h6>
        </div>
        <div class="card-body p-0">
          <pre class="mb-0 p-3" style="background:#1e1e1e;color:#ffd700;font-size:0.8rem;border-radius:0 0 0.35rem 0.35rem;"><%= html_escape(@secrets_template) %></pre>
        </div>
        <div class="card-footer text-muted small">
          <i class="fas fa-shield-alt me-1"></i>
          Secret values are never shown. The actual secrets file is generated at deploy time with 0600 permissions.
        </div>
      </div>

      <div class="card shadow">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-2"></i>How it works
          </h6>
        </div>
        <div class="card-body small">
          <p class="mb-2">Vantage generates these files at deploy time from your configuration and writes them to a secure temp directory before running <code>kamal deploy</code>.</p>
          <ul class="mb-0">
            <li>The <code>deploy.yml</code> is safe to version control (no secrets)</li>
            <li><code>.kamal/secrets</code> contains actual secret values — never committed</li>
            <li>Temp files are cleaned up after every operation</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function copyCode(id) {
    const text = document.getElementById(id).innerText;
    navigator.clipboard.writeText(text).then(() => {
      const btn = event.target.closest("button");
      btn.innerHTML = '<i class="fas fa-check me-1"></i>Copied!';
      setTimeout(() => { btn.innerHTML = '<i class="fas fa-copy me-1"></i>Copy'; }, 2000);
    });
  }
</script>
