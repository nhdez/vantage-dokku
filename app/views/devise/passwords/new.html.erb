<% content_for :title, "Forgot Password - Vantage Dokku" %>

<div class="bg-slate-900/50 border border-slate-800/50 backdrop-blur-lg rounded-2xl p-8 lg:p-12 shadow-2xl shadow-violet-900/10">
  <div class="text-center">
    <h1 class="text-3xl font-bold text-white mb-2">Forgot Your Password?</h1>
    <p class="text-slate-400">
      Enter your email and we'll send you instructions to reset your password.
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-6">
      <div>
        <%= f.label :email, class: "text-sm font-medium text-slate-300" %>
        <div class="mt-2">
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "you@example.com" %>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <%= f.submit "Send Reset Instructions", class: "btn-glow w-full cursor-pointer px-4 py-3 font-semibold text-white bg-violet-600 hover:bg-violet-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-violet-500 transition-all duration-200" %>
    </div>
    
    <div class="mt-6 text-center">
      <%= link_to "Back to Sign In", new_session_path(resource_name), class: "font-medium text-sm text-violet-400 hover:text-violet-300 transition-colors" %>
    </div>
  <% end %>
</div>
