<% content_for :title, "Sign In - Vantage Dokku" %>

<div class="bg-slate-900/50 border border-slate-800/50 backdrop-blur-lg rounded-2xl p-8 lg:p-12 shadow-2xl shadow-violet-900/10">
  <div class="text-center">
    <h1 class="text-3xl font-bold text-white mb-2">Sign In to Vantage</h1>
    <p class="text-slate-400">
      <% if devise_mapping.registerable? %>
        Don't have an account? <%= link_to "Sign Up", new_registration_path(resource_name), class: "font-medium text-violet-400 hover:text-violet-300 transition-colors" %>.
      <% else %>
        Welcome back. Please sign in to continue.
      <% end %>
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8" }) do |f| %>
    <div class="space-y-6">
      <div>
        <%= f.label :email, class: "text-sm font-medium text-slate-300" %>
        <div class="mt-2">
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "you@example.com" %>
        </div>
      </div>

      <div>
        <%= f.label :password, class: "text-sm font-medium text-slate-300" %>
        <div class="mt-2">
          <%= f.password_field :password, 
              autocomplete: "current-password", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "••••••••" %>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between mt-6">
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 bg-slate-800 border-slate-600 text-violet-500 focus:ring-violet-500/50 focus:ring-offset-slate-900 rounded" %>
          <%= f.label :remember_me, class: "ml-2 block text-sm text-slate-400" %>
        </div>
      <% end %>

      <% if devise_mapping.recoverable? %>
        <div class="text-sm">
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "font-medium text-violet-400 hover:text-violet-300 transition-colors" %>
        </div>
      <% end %>
    </div>

    <div class="mt-8">
      <%= f.submit "Sign In", class: "btn-glow w-full cursor-pointer px-4 py-3 font-semibold text-white bg-violet-600 hover:bg-violet-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-violet-500 transition-all duration-200" %>
    </div>
  <% end %>

  <% if OauthSetting.google_enabled? %>
    <div class="my-6 flex items-center">
      <div class="flex-grow border-t border-slate-800"></div>
      <span class="mx-4 text-xs font-medium text-slate-500 uppercase">Or</span>
      <div class="flex-grow border-t border-slate-800"></div>
    </div>

    <div>
      <%= button_to user_google_oauth2_omniauth_authorize_path, 
          method: :post, 
          class: "w-full flex items-center justify-center px-4 py-3 border border-slate-700 bg-slate-800/50 rounded-lg text-slate-200 hover:bg-slate-800 transition-colors duration-200",
          data: { turbo: "false" } do %>
        <i class="fab fa-google text-lg mr-3 text-red-400"></i>
        <span class="font-medium text-sm">Continue with Google</span>
      <% end %>
    </div>
  <% end %>
</div>
