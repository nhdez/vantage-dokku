<% content_for :title, "Sign Up - Vantage Dokku" %>

<div class="bg-slate-900/50 border border-slate-800/50 backdrop-blur-lg rounded-2xl p-8 lg:p-12 shadow-2xl shadow-violet-900/10">
  <div class="text-center">
    <h1 class="text-3xl font-bold text-white mb-2">Create Your Account</h1>
    <p class="text-slate-400">
      Already have an account? <%= link_to "Sign In", new_session_path(resource_name), class: "font-medium text-violet-400 hover:text-violet-300 transition-colors" %>.
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-6">
      <div>
        <%= f.label :email, class: "text-sm font-medium text-slate-300" %>
        <div class="mt-2">
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "you@example.com" %>
        </div>
      </div>

      <div>
        <%= f.label :password, class: "text-sm font-medium text-slate-300" %>
        <% if @minimum_password_length %>
          <em class="text-xs text-slate-500">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <div class="mt-2">
          <%= f.password_field :password, 
              autocomplete: "new-password", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "••••••••" %>
        </div>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "text-sm font-medium text-slate-300" %>
        <div class="mt-2">
          <%= f.password_field :password_confirmation, 
              autocomplete: "new-password", 
              class: "form-input-glow w-full bg-slate-900 border-2 border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 transition-all duration-200",
              placeholder: "••••••••" %>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <%= f.submit "Sign Up", class: "btn-glow w-full cursor-pointer px-4 py-3 font-semibold text-white bg-violet-600 hover:bg-violet-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-violet-500 transition-all duration-200" %>
    </div>
  <% end %>
</div>
