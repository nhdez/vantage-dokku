# ============================================================
# Vantage-Dokku — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Rails core ──────────────────────────────────────────────
# Generate with: bin/rails secret
SECRET_KEY_BASE=

# Hostname used for ActionCable, email links, and OAuth callbacks
# Development: localhost:3000  |  Production: your-domain.com
APP_HOST=localhost:3000

RAILS_ENV=development

# ── Database ─────────────────────────────────────────────────
# Defaults to SQLite in development; set for PostgreSQL in production
DATABASE_URL=

# ── Active Record Encryption ─────────────────────────────────
# Generate with: bin/rails db:encryption:init
# In development these live in config/credentials/development.yml.enc
# In production set them as env vars or in production credentials
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── SSH / Dokku ───────────────────────────────────────────────
# Path to the SSH private key Vantage uses to connect to servers
DOKKU_SSH_KEY_PATH=/home/user/.ssh/id_ed25519

# Corresponding public key content (used when provisioning Dokku SSH keys)
DOKKU_SSH_PUBLIC_KEY=

# Email passed to Let's Encrypt when enabling SSL via Dokku
DOKKU_LETSENCRYPT_EMAIL=

# ── OAuth (Google) ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Address used as From on outgoing mail
MAIL_FROM=noreply@example.com

# Set to "true" to send real emails in development (default: letter_opener)
USE_REAL_EMAIL=false

# ── Workers / Concurrency ─────────────────────────────────────
# Number of Puma web workers (0 = single-process, good for development)
WEB_CONCURRENCY=0

# Set to "true" to run SolidQueue inside the Puma process (development only)
SOLID_QUEUE_IN_PUMA=true

# ── Misc ──────────────────────────────────────────────────────
# Set to "true" to disable background health monitoring (useful in CI)
SKIP_HEALTH_MONITORING=false
